# =====================================================
# ABENA SHARED SDK ENVIRONMENT CONFIGURATION
# =====================================================

# SDK Service Configuration
SDK_PORT=3001
SDK_HOST=0.0.0.0
SDK_ENVIRONMENT=production
SDK_VERSION=1.0.0

# SDK Performance Settings
SDK_TIMEOUT=30000
SDK_RETRY_ATTEMPTS=3
SDK_RETRY_DELAY=1000
SDK_CACHE_TTL=3600
SDK_CACHE_MAX_SIZE=1000

# Circuit Breaker Configuration
SDK_CIRCUIT_BREAKER_ENABLED=true
SDK_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
SDK_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60000
SDK_CIRCUIT_BREAKER_MONITORING_WINDOW=60000

# Service Discovery
SDK_DISCOVERY_TYPE=kubernetes
SDK_DISCOVERY_NAMESPACE=abena-ihr
SDK_DISCOVERY_REFRESH_INTERVAL=30000
SDK_DISCOVERY_HEALTH_CHECK_INTERVAL=10000

# Caching Configuration
SDK_CACHE_TYPE=redis
SDK_CACHE_REDIS_URL=redis://localhost:6379
SDK_CACHE_REDIS_PASSWORD=your_redis_password
SDK_CACHE_REDIS_DB=1

# Authentication & Security
SDK_AUTH_TYPE=jwt
SDK_JWT_SECRET=your-super-secret-jwt-key-min-32-characters
SDK_TOKEN_REFRESH_INTERVAL=300000
SDK_TOKEN_EXPIRY_BUFFER=60000
SDK_ENCRYPTION_KEY=your-32-character-encryption-key

# Logging Configuration
SDK_LOG_LEVEL=info
SDK_LOG_FORMAT=json
SDK_LOG_OUTPUT=stdout
SDK_ENABLE_REQUEST_LOGGING=true
SDK_ENABLE_PERFORMANCE_LOGGING=true

# Metrics & Monitoring
SDK_METRICS_ENABLED=true
SDK_METRICS_ENDPOINT=/metrics
SDK_METRICS_COLLECTION_INTERVAL=15000
SDK_ENABLE_HISTOGRAMS=true
SDK_ENABLE_COUNTERS=true

# Health Checks
SDK_HEALTH_ENABLED=true
SDK_HEALTH_ENDPOINT=/health
SDK_READINESS_ENDPOINT=/ready
SDK_LIVENESS_ENDPOINT=/live
SDK_HEALTH_CHECK_INTERVAL=30000

# External Service URLs
SDK_FHIR_SERVER_URL=https://your-fhir-server.com/fhir
SDK_HL7_ENDPOINT=https://your-hl7-endpoint.com
SDK_EPIC_API_URL=https://api.epic.com
SDK_CERNER_API_URL=https://api.cerner.com

# External Service Authentication
SDK_EPIC_CLIENT_ID=your_epic_client_id
SDK_EPIC_CLIENT_SECRET=your_epic_client_secret
SDK_CERNER_API_KEY=your_cerner_api_key

# Payment & Communication Services
SDK_STRIPE_SECRET_KEY=sk_live_...
SDK_TWILIO_ACCOUNT_SID=your_twilio_sid
SDK_TWILIO_AUTH_TOKEN=your_twilio_token
SDK_TWILIO_PHONE_NUMBER=+1234567890

# Storage Services
SDK_S3_ENDPOINT=https://s3.amazonaws.com
SDK_S3_BUCKET=abena-ihr-documents
SDK_AWS_ACCESS_KEY_ID=your_aws_access_key
SDK_AWS_SECRET_ACCESS_KEY=your_aws_secret_key
SDK_AWS_REGION=us-east-1

# Monitoring Integration
SDK_SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io
SDK_DATADOG_API_KEY=your_datadog_api_key
SDK_NEW_RELIC_LICENSE_KEY=your_newrelic_license_key

# Feature Flags
SDK_UNIVERSAL_CLIENT_ENABLED=true
SDK_SERVICE_DISCOVERY_ENABLED=true
SDK_CIRCUIT_BREAKER_ENABLED=true
SDK_CACHING_ENABLED=true
SDK_METRICS_ENABLED=true
SDK_HEALTH_CHECKS_ENABLED=true
SDK_FHIR_SUPPORT_ENABLED=true
SDK_HL7_SUPPORT_ENABLED=true
SDK_EPIC_INTEGRATION_ENABLED=true
SDK_CERNER_INTEGRATION_ENABLED=true
SDK_ENCRYPTION_ENABLED=true
SDK_AUDIT_LOGGING_ENABLED=true
SDK_COMPLIANCE_ENABLED=true

# Development Overrides
# SDK_LOG_LEVEL=debug
# SDK_METRICS_ENABLED=false
# SDK_CACHE_TTL=300 