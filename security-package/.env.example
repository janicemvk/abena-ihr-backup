# Abena IHR Security Package - Environment Variables
# Copy this file to .env and fill in your values

# JWT Secret Key (MUST be at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-AT-LEAST-32-CHARACTERS-LONG

# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/abena_ihr

# Redis Connection (for rate limiting)
REDIS_URL=redis://localhost:6379/0
# Or specify separately:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# File Upload Directory
UPLOAD_DIR=./uploads

# ClamAV Configuration (optional, for virus scanning)
CLAMAV_ENABLED=false
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl

