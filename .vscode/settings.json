{
  "rust-analyzer.cargo.target": "x86_64-pc-windows-msvc",
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": ["--all-targets"],
  "files.exclude": {
    "**/target": true
  },
  "search.exclude": {
    "**/target": true,
    "**/node_modules": true
  },
  "editor.formatOnSave": true,
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4
  }
}
