# eCBome ML Engine Configuration

# Server Configuration
PORT=8007
NODE_ENV=development

# ABENA SDK Configuration
ABENA_AUTH_SERVICE_URL=http://localhost:3001
ABENA_DATA_SERVICE_URL=http://localhost:8001
ABENA_PRIVACY_SERVICE_URL=http://localhost:8002
ABENA_BLOCKCHAIN_SERVICE_URL=http://localhost:8003
ABENA_ML_SERVICE_URL=http://localhost:8007

# ML Configuration
ML_MODEL_UPDATE_INTERVAL=3600000        # Update models every hour (ms)
ML_PROCESSING_CAPACITY=2300000          # 2.3M data points/second
ML_FEATURE_COUNT=144                    # 12 modules × 12 features each
ML_PREDICTION_WINDOW_WEEKS=8            # 8-week prediction window

# Model Accuracy Targets
ML_PATTERN_RECOGNITION_ACCURACY=0.978   # 97.8% target accuracy
ML_PREDICTIVE_MODELING_ACCURACY=0.942   # 94.2% target accuracy

# Rate Limiting
API_RATE_LIMIT_REQUESTS=100             # Requests per window
API_RATE_LIMIT_WINDOW=60                # Window in seconds

# Security
API_CORS_ORIGIN=*                       # CORS allowed origins
API_HELMET_ENABLED=true                 # Enable security headers

# Database Configuration (if using persistent storage)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecbome_ml
DB_USER=ecbome_user
DB_PASSWORD=secure_password

# Redis Configuration (for rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=info                          # debug, info, warn, error
LOG_FORMAT=json                         # json, simple
LOG_FILE=logs/ecbome-ml.log

# Monitoring & Analytics
ANALYTICS_ENABLED=true
METRICS_COLLECTION_INTERVAL=300000      # 5 minutes
HEALTH_CHECK_INTERVAL=30000             # 30 seconds

# Feature Extraction Configuration
FEATURE_EXTRACTION_TIMEOUT=5000         # 5 seconds
FEATURE_NORMALIZATION_ENABLED=true

# Model Training Configuration
TRAINING_BATCH_SIZE=32
TRAINING_EPOCHS=100
TRAINING_LEARNING_RATE=0.001
TRAINING_VALIDATION_SPLIT=0.2

# Anomaly Detection Configuration
ANOMALY_THRESHOLD=0.05
ANOMALY_SENSITIVITY=medium              # low, medium, high

# Risk Assessment Configuration
RISK_THRESHOLD_LOW=0.2
RISK_THRESHOLD_MEDIUM=0.4
RISK_THRESHOLD_HIGH=0.6
RISK_THRESHOLD_VERY_HIGH=0.8

# Notification Configuration
NOTIFICATIONS_ENABLED=true
ALERT_WEBHOOK_URL=https://your-webhook-url.com
EMAIL_NOTIFICATIONS_ENABLED=false

# Development Configuration
DEV_MODE=true
DEBUG_ENABLED=true
PROFILING_ENABLED=false
MOCK_DATA_ENABLED=true 