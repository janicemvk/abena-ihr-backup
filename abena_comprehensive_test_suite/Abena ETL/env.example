# Abena IHR System Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Security Configuration
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database Configuration
DATABASE_URL=postgresql://abena_user:your-password@localhost:5432/abena_ihr
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abena_ihr
DB_USER=abena_user
DB_PASSWORD=your-database-password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# EMR Integration
EMR_BASE_URL=https://your-emr-system.com/fhir
EMR_CLIENT_ID=your-emr-client-id
EMR_CLIENT_SECRET=your-emr-client-secret
EMR_TIMEOUT_SECONDS=30
FHIR_VERSION=R4

# ML Model Configuration
MODEL_UPDATE_THRESHOLD=0.05
PREDICTION_CONFIDENCE_THRESHOLD=0.6
MODEL_STORAGE_PATH=./models/

# Security & Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Alert Configuration
CRITICAL_ALERT_ESCALATION_MINUTES=15
HIGH_ALERT_ESCALATION_MINUTES=60
MEDIUM_ALERT_ESCALATION_MINUTES=240

# Logging Configuration
LOG_FILE_PATH=./logs/abena_ihr.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Testing Configuration (for test environment)
TEST_DATABASE_URL=postgresql://abena_user:your-password@localhost:5432/abena_ihr_test

# External API Keys (if needed)
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key 