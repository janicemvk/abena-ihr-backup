# =============================================================================
# Abena IHR Intelligence Layer Environment Configuration
# =============================================================================

# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost/abena_ihr
REDIS_URL=redis://localhost:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
PROMETHEUS_PORT=8001

# Email Notification Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@abena-ihr.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=alerts@abena-ihr.com
TO_EMAILS=admin@abena-ihr.com,ops@abena-ihr.com

# Slack Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/intelligence_layer.log

# Alert Configuration
DEFAULT_ALERT_COOLDOWN_MINUTES=15
HIGH_ERROR_RATE_THRESHOLD=0.05
SLOW_RESPONSE_TIME_THRESHOLD=30.0
LOW_DATA_QUALITY_THRESHOLD=0.7

# Data Quality Configuration
ANOMALY_DETECTION_CONTAMINATION=0.1
QUALITY_ANALYSIS_BATCH_SIZE=1000

# Monitoring Configuration
HEALTH_CHECK_INTERVAL_SECONDS=60
FAILURE_DETECTION_INTERVAL_SECONDS=300
SYSTEM_HEALTH_THRESHOLD=50

# Security Configuration
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=your_secure_api_key_here
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Performance Configuration
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT_SECONDS=30
CACHE_TTL_SECONDS=3600

# Database Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis Configuration
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5 