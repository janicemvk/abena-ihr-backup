# Abena IHR Blockchain Service Environment Variables

# Service Configuration
PORT=8003

# Database Configuration
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=abena_ihr
MONGO_USERNAME=abena_user
MONGO_PASSWORD=abena_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password
REDIS_DB=0

# Authentication Service
AUTH_SERVICE_URL=http://localhost:3001
JWT_SECRET=your-secret-key-here

# Hyperledger Fabric Configuration
FABRIC_CONFIG_PATH=./config/connection.yaml
CHANNEL_NAME=healthchannel
CHAINCODE_NAME=healthrecords
ORGANIZATION=Org1MSP
USER_NAME=User1

# Blockchain Network Configuration
FABRIC_CA_URL=https://localhost:7054
FABRIC_PEER_URL=grpcs://localhost:7051
FABRIC_ORDERER_URL=grpcs://localhost:7050

# Security Configuration
ENCRYPTION_KEY=your-encryption-key-here
CORS_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance Configuration
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30s
IDLE_TIMEOUT=60s

# Development Configuration
DEBUG=false
ENABLE_SWAGGER=true 