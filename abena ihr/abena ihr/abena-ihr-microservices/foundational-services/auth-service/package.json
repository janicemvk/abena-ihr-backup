{
  "name": "@abena-ihr/auth-service",
  "version": "1.0.0",
  "description": "Authentication and Authorization Service for Abena IHR",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security-audit": "npm audit",
    "docker:build": "docker build -t abena-auth-service .",
    "docker:run": "docker run -p 8000:8000 abena-auth-service"
  },
  "keywords": [
    "authentication",
    "authorization",
    "jwt",
    "oauth",
    "healthcare",
    "security",
    "microservice"
  ],
  "author": "Abena IHR Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^0.1.0",
    "passport-saml": "^3.2.4",
    "redis": "^4.6.10",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.0",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express-async-errors": "^3.1.1",
    "http-status-codes": "^2.3.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "aws-sdk": "^2.1473.0",
    "google-auth-library": "^9.0.0",
    "msal-node": "^2.1.0",
    "saml2-js": "^3.0.5",
    "ldapjs": "^2.3.3",
    "node-cache": "^5.1.2",
    "express-winston": "^4.2.0",
    "express-brute": "^1.0.1",
    "express-brute-redis": "^0.0.1",
    "hpp": "^0.2.3",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "express-http-proxy": "^1.6.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "compression-webpack-plugin": "^10.0.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.4.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^1.7.1",
    "prettier": "^3.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.3",
    "@types/express": "^4.17.20",
    "@types/bcryptjs": "^2.4.5",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/cors": "^2.8.15",
    "@types/uuid": "^9.0.5",
    "@types/multer": "^1.4.9",
    "@types/compression": "^1.7.4",
    "@types/express-session": "^1.17.10",
    "@types/morgan": "^1.9.9",
    "@types/nodemailer": "^6.4.12",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.9",
    "@types/ldapjs": "^2.2.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abena-ihr/auth-service.git"
  },
  "bugs": {
    "url": "https://github.com/abena-ihr/auth-service/issues"
  },
  "homepage": "https://github.com/abena-ihr/auth-service#readme",
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/**/*.spec.js"
    ]
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base",
      "plugin:security/recommended"
    ],
    "env": {
      "node": true,
      "jest": true
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
} 