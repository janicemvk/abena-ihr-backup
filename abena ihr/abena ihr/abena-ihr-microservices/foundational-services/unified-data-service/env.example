# Abena IHR Unified Data Service - Environment Variables
# ======================================================
# 
# Copy this file to .env and update the values as needed
# cp env.example .env

# ======================================================
# DATABASE CONFIGURATION
# ======================================================

# PostgreSQL Database Settings
POSTGRES_PASSWORD=secure_password_123
POSTGRES_USER=abena_admin
POSTGRES_DB=abena_unified_db
POSTGRES_HOST=unified-postgres
POSTGRES_PORT=5432

# PostgreSQL Connection Settings
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# PostgreSQL Logging
POSTGRES_LOG_LEVEL=INFO
POSTGRES_LOG_STATEMENT=all
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000

# ======================================================
# REDIS CONFIGURATION
# ======================================================

# Redis Settings
REDIS_PASSWORD=redis_password_123
REDIS_HOST=unified-redis
REDIS_PORT=6379
REDIS_DB=0

# Redis Performance Settings
REDIS_MAX_MEMORY=512mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru
REDIS_SAVE_INTERVAL=900
REDIS_SAVE_CHANGES=1

# ======================================================
# NETWORK CONFIGURATION
# ======================================================

# Docker Network Settings
NETWORK_SUBNET=172.20.0.0/16
NETWORK_GATEWAY=172.20.0.1

# Service Ports
POSTGRES_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379

# ======================================================
# BACKUP CONFIGURATION
# ======================================================

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false

# Backup Storage
BACKUP_STORAGE_PATH=./backups
BACKUP_STORAGE_TYPE=local  # local, s3, azure, gcs

# ======================================================
# MONITORING CONFIGURATION
# ======================================================

# Health Check Settings
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=40s

# Monitoring Settings
MONITORING_ENABLED=true
MONITORING_INTERVAL=60s
MONITORING_LOG_PATH=./monitoring

# ======================================================
# MIGRATION CONFIGURATION
# ======================================================

# Migration Settings
MIGRATION_AUTO_RUN=true
MIGRATION_PATH=./migrations
MIGRATION_SCHEMA_PATH=./database/schemas

# ======================================================
# SECURITY CONFIGURATION
# ======================================================

# SSL/TLS Settings
SSL_ENABLED=false
SSL_CERT_FILE=/etc/ssl/certs/server.crt
SSL_KEY_FILE=/etc/ssl/private/server.key
SSL_CA_FILE=/etc/ssl/certs/ca.crt

# Authentication Settings
AUTH_REQUIRED=true
AUTH_METHOD=password  # password, certificate, ldap
AUTH_TIMEOUT=300

# ======================================================
# PERFORMANCE CONFIGURATION
# ======================================================

# Connection Pooling
POOL_MIN_SIZE=5
POOL_MAX_SIZE=20
POOL_TIMEOUT=30

# Query Optimization
QUERY_TIMEOUT=300
STATEMENT_TIMEOUT=600
LOCK_TIMEOUT=5000

# ======================================================
# LOGGING CONFIGURATION
# ======================================================

# Log Levels
LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR
LOG_FORMAT=json  # json, text
LOG_OUTPUT=stdout  # stdout, file, syslog

# Log Files
LOG_FILE_PATH=./logs
LOG_FILE_MAX_SIZE=100MB
LOG_FILE_MAX_FILES=10

# ======================================================
# DEVELOPMENT CONFIGURATION
# ======================================================

# Development Settings
DEBUG_MODE=false
DEVELOPMENT_MODE=false
TESTING_MODE=false

# Test Database
TEST_POSTGRES_DB=abena_unified_test
TEST_REDIS_DB=1

# ======================================================
# INTEGRATION CONFIGURATION
# ======================================================

# External Service URLs
ANALYTICS_SERVICE_URL=http://analytics-service:8001
CLINICAL_SERVICE_URL=http://clinical-service:8002
PRIVACY_SERVICE_URL=http://privacy-service:8003
BLOCKCHAIN_SERVICE_URL=http://blockchain-service:8004

# API Settings
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000

# ======================================================
# COMPLIANCE CONFIGURATION
# ======================================================

# HIPAA Compliance
HIPAA_COMPLIANCE_ENABLED=true
HIPAA_AUDIT_LOGGING=true
HIPAA_DATA_ENCRYPTION=true

# Data Retention
DATA_RETENTION_DAYS=2555  # 7 years
AUDIT_RETENTION_DAYS=3650  # 10 years

# ======================================================
# CUSTOMIZATION
# ======================================================

# Custom Settings
CUSTOM_TIMEZONE=UTC
CUSTOM_LOCALE=en_US.UTF-8
CUSTOM_CHARSET=UTF-8

# Feature Flags
FEATURE_AUDIT_LOGGING=true
FEATURE_DATA_QUALITY_MONITORING=true
FEATURE_AUTOMATIC_BACKUP=true
FEATURE_HEALTH_MONITORING=true

# ======================================================
# DEPLOYMENT CONFIGURATION
# ======================================================

# Deployment Environment
DEPLOYMENT_ENV=development  # development, staging, production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_VERSION=1.0.0

# Resource Limits
RESOURCE_MEMORY_LIMIT=4G
RESOURCE_CPU_LIMIT=2.0
RESOURCE_DISK_LIMIT=100G

# ======================================================
# NOTES
# ======================================================

# Important Notes:
# 1. Change all default passwords in production
# 2. Use strong, unique passwords for each environment
# 3. Enable SSL/TLS in production environments
# 4. Configure proper backup storage for production
# 5. Set appropriate resource limits based on usage
# 6. Enable monitoring and alerting in production
# 7. Configure proper logging for compliance requirements
# 8. Test all configurations in staging before production 