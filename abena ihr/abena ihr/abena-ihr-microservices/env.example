# =============================================
# ABENA IHR MICROSERVICES - ENVIRONMENT VARIABLES
# =============================================

# =============================================
# DATABASE CONFIGURATION
# =============================================

# PostgreSQL
POSTGRES_DB=abena_ihr
POSTGRES_USER=abena_user
POSTGRES_PASSWORD=abena_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://abena_user:abena_pass@localhost:5432/abena_ihr

# MongoDB
MONGODB_URL=mongodb://localhost:27017/abena_ihr
MONGODB_USERNAME=admin
MONGODB_PASSWORD=admin123

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# =============================================
# KAFKA CONFIGURATION
# =============================================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_DATA=raw-data
KAFKA_TOPIC_PROCESSED_DATA=processed-data
KAFKA_TOPIC_ERRORS=data-errors
KAFKA_TOPIC_AUDIT=audit-events
KAFKA_TOPIC_NOTIFICATIONS=notifications

# =============================================
# SECURITY CONFIGURATION
# =============================================

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key_here
ENCRYPTION_ALGORITHM=AES-256-GCM

# OAuth2 Configuration
OAUTH2_CLIENT_ID=your_oauth2_client_id
OAUTH2_CLIENT_SECRET=your_oauth2_client_secret
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback

# =============================================
# BLOCKCHAIN CONFIGURATION
# =============================================

BLOCKCHAIN_NETWORK=testnet
BLOCKCHAIN_PROVIDER=ethereum
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/your_project_id
BLOCKCHAIN_PRIVATE_KEY=your_private_key_here
BLOCKCHAIN_CONTRACT_ADDRESS=0x...

# =============================================
# SERVICE PORTS
# =============================================

# Foundational Services
BLOCKCHAIN_SERVICE_PORT=8000
DATA_INGESTION_SERVICE_PORT=8001
PRIVACY_SECURITY_SERVICE_PORT=8002
UNIFIED_DATA_SERVICE_PORT=8003
AUTH_SERVICE_PORT=8004

# Application Services
ANALYTICS_ENGINE_SERVICE_PORT=8010
CLINICAL_DECISION_SUPPORT_SERVICE_PORT=8011
PROVIDER_WORKFLOW_SERVICE_PORT=8012
TELEMEDICINE_SERVICE_PORT=8013
PATIENT_ENGAGEMENT_SERVICE_PORT=8014

# Infrastructure Services
KONG_API_GATEWAY_PORT=8005
KONG_ADMIN_PORT=8006
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_PORT=16686
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# =============================================
# MONITORING CONFIGURATION
# =============================================

# Prometheus
PROMETHEUS_RETENTION_TIME=200h
PROMETHEUS_STORAGE_PATH=/prometheus

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SECURITY_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/app/logs

# =============================================
# EXTERNAL SERVICES
# =============================================

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# SMS Service
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# File Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=abena-ihr-storage

# =============================================
# HEALTHCARE INTEGRATIONS
# =============================================

# HL7 FHIR
FHIR_BASE_URL=https://fhir.example.com
FHIR_CLIENT_ID=your_fhir_client_id
FHIR_CLIENT_SECRET=your_fhir_client_secret

# Lab Integration
LAB_API_URL=https://lab.example.com/api
LAB_API_KEY=your_lab_api_key

# Pharmacy Integration
PHARMACY_API_URL=https://pharmacy.example.com/api
PHARMACY_API_KEY=your_pharmacy_api_key

# =============================================
# AI/ML SERVICES
# =============================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# TensorFlow Serving
TENSORFLOW_SERVING_URL=http://localhost:8501

# ML Model Storage
ML_MODEL_BUCKET=abena-ml-models
ML_MODEL_VERSION=v1.0

# =============================================
# COMPLIANCE CONFIGURATION
# =============================================

# HIPAA Compliance
HIPAA_COMPLIANCE_ENABLED=true
HIPAA_AUDIT_LOG_RETENTION_DAYS=2555
HIPAA_ENCRYPTION_REQUIRED=true

# GDPR Compliance
GDPR_COMPLIANCE_ENABLED=true
GDPR_DATA_RETENTION_DAYS=2555
GDPR_CONSENT_REQUIRED=true

# =============================================
# DEVELOPMENT CONFIGURATION
# =============================================

# Environment
ENVIRONMENT=development
DEBUG=true
RELOAD=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================
# PRODUCTION OVERRIDES
# =============================================

# Uncomment and modify for production
# ENVIRONMENT=production
# DEBUG=false
# RELOAD=false
# LOG_LEVEL=WARNING
# CORS_ORIGINS=https://yourdomain.com
# RATE_LIMIT_REQUESTS=1000 