# Service Configuration
PORT=8004
SERVICE_NAME=analytics-engine-service

# Foundational Services URLs
AUTH_SERVICE_URL=http://auth-service:3001
DATA_SERVICE_URL=http://data-ingestion-service:8001
PRIVACY_SERVICE_URL=http://privacy-security-service:8002
BLOCKCHAIN_SERVICE_URL=http://blockchain-service:8003

# Database Configuration
DATABASE_URL=postgresql://postgres:password@unified-database:5432/abena_ihr_data
REDIS_URL=redis://:password@redis-cache:6379

# Analytics Configuration
MODEL_UPDATE_INTERVAL=24h
PREDICTION_CACHE_TTL=3600
MONITORING_FREQUENCY_MINUTES=5
MAX_CONCURRENT_SESSIONS=100

# ML Model Configuration
MODEL_STORAGE_PATH=/app/models
ENABLE_GPU=false
BATCH_SIZE=32
MAX_PREDICTION_REQUESTS_PER_MINUTE=1000

# Logging and Monitoring
LOG_LEVEL=INFO
ENABLE_PERFORMANCE_METRICS=true
PROMETHEUS_METRICS_PORT=9004 