# Abena IHR - Clinical Outcomes Management System
# Environment Configuration Template
# Copy this file to .env and update the values

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://postgrel:2114***Million@localhost:5432/abena_ihr
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# API Configuration
# =============================================================================
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=0M9-XM3g22BhPCsG205HhOKQ1W6KJdfoOy-9DjKSCx8
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://abena-ihr.com,https://www.abena-ihr.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# Trusted Hosts
# =============================================================================
TRUSTED_HOSTS=localhost,127.0.0.1,abena-ihr.com,www.abena-ihr.com,*.abena-ihr.com

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# =============================================================================
# Redis Configuration (for caching and sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# Email Configuration (for notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@abena-ihr.com
SMTP_FROM_NAME=Abena IHR System

# =============================================================================
# File Upload Configuration
# =============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10MB
ALLOWED_FILE_TYPES=.csv,.json,.xlsx,.pdf

# =============================================================================
# Export Configuration
# =============================================================================
EXPORT_DIR=exports
EXPORT_RETENTION_DAYS=30
EXPORT_MAX_SIZE=100MB

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Monitoring and Metrics
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Development Settings
# =============================================================================
# Set to true to enable development features
DEVELOPMENT_MODE=true

# Auto-reload on code changes
AUTO_RELOAD=true

# Enable debug toolbar
DEBUG_TOOLBAR=false

# =============================================================================
# Testing Configuration
# =============================================================================
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/abena_ihr_test
TESTING=false

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_ANALYTICS=true
ENABLE_EXPORT=true
ENABLE_NOTIFICATIONS=false
ENABLE_AUDIT_LOG=true

# =============================================================================
# External Services (for future integrations)
# =============================================================================
# EHR Integration
EHR_API_URL=
EHR_API_KEY=

# Analytics Service
ANALYTICS_API_URL=
ANALYTICS_API_KEY=

# Notification Service
NOTIFICATION_API_URL=
