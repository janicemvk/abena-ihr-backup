// Personalized Medicine Functions
const calculatePersonalizedDosing = (patientData, geneticProfile, currentMetrics) => {
  const dosing = {
    cbd: {
      baseDose: 10, // mg
      weightFactor: patientData.weight / 70, // normalized to 70kg
      metabolismFactor: geneticProfile.polymorphisms.CYP2C9.rs1799853 === 'CC' ? 1.2 : 1.0,
      geneticFactor: geneticProfile.personalizedTraits.cannabisSensitivity === 'high' ? 0.8 : 1.0,
      recommendedDose: 0,
      titration: 'Start with 5mg twice daily, increase by 5mg weekly'
    },
    thc: {
      baseDose: 2.5, // mg
      toleranceFactor: 1.0, // will be updated based on usage history
      sensitivityFactor: geneticProfile.personalizedTraits.cannabisSensitivity === 'high' ? 0.5 : 1.0,
      recommendedDose: 0,
      titration: 'Start with 1mg, increase slowly based on response'
    },
    supplements: {
      omega3: {
        dose: 2000, // mg EPA/DHA
        rationale: 'Anti-inflammatory support based on elevated inflammation markers',
        timing: 'With meals'
      },
      magnesium: {
        dose: 400, // mg
        rationale: 'Stress reduction and sleep support',
        timing: 'Before bed'
      },
      vitaminD: {
        dose: 2000, // IU
        rationale: 'Immune support and mood enhancement',
        timing: 'Morning with fat'
      }
    }
  };

  // Calculate recommended doses
  dosing.cbd.recommendedDose = Math.round(
    dosing.cbd.baseDose * 
    dosing.cbd.weightFactor * 
    dosing.cbd.metabolismFactor * 
    dosing.cbd.geneticFactor
  );

  dosing.thc.recommendedDose = Math.round(
    dosing.thc.baseDose * 
    dosing.thc.toleranceFactor * 
    dosing.thc.sensitivityFactor * 10
  ) / 10;

  return dosing;
};

const generateTreatmentProtocol = (patientData, geneticProfile, currentMetrics, goals) => {
  const protocol = {
    primaryGoals: goals,
    timeline: '12_weeks',
    phases: {
      phase1: {
        duration: '4_weeks',
        focus: 'stabilization',
        interventions: [],
        monitoring: []
      },
      phase2: {
        duration: '4_weeks',
        focus: 'optimization',
        interventions: [],
        monitoring: []
      },
      phase3: {
        duration: '4_weeks',
        focus: 'maintenance',
        interventions: [],
        monitoring: []
      }
    },
    personalization: {
      geneticFactors: [],
      lifestyleFactors: [],
      environmentalFactors: []
    }
  };

  // Determine primary interventions based on current metrics and goals
  if (currentMetrics.stressResponse > 0.6) {
    protocol.phases.phase1.interventions.push(...PersonalizedMedicine.treatmentProtocols.protocols.stressManagement.primary);
    protocol.phases.phase1.monitoring.push(...PersonalizedMedicine.treatmentProtocols.protocols.stressManagement.monitoring);
  }

  if (currentMetrics.inflammationMarkers > 0.5) {
    protocol.phases.phase1.interventions.push(...PersonalizedMedicine.treatmentProtocols.protocols.inflammationReduction.primary);
    protocol.phases.phase1.monitoring.push(...PersonalizedMedicine.treatmentProtocols.protocols.inflammationReduction.monitoring);
  }

  // Add personalized factors
  protocol.personalization.geneticFactors = PersonalizedMedicine.treatmentProtocols.personalization.geneticFactors;
  protocol.personalization.lifestyleFactors = PersonalizedMedicine.treatmentProtocols.personalization.lifestyleFactors;
  protocol.personalization.environmentalFactors = PersonalizedMedicine.treatmentProtocols.personalization.environmentalFactors;

  return protocol;
};

const analyzeGeneticRiskFactors = (geneticProfile) => {
  const riskAnalysis = {
    overallRisk: 0,
    riskFactors: [],
    recommendations: [],
    monitoring: []
  };

  // Calculate overall risk based on genetic factors
  const riskFactors = geneticProfile.riskFactors;
  riskAnalysis.overallRisk = Object.values(riskFactors).reduce((sum, risk) => sum + risk, 0) / Object.keys(riskFactors).length;

  // Generate specific recommendations
  if (riskFactors.endocannabinoidDeficiency > 0.3) {
    riskAnalysis.recommendations.push('Consider FAAH inhibitor therapy');
    riskAnalysis.monitoring.push('Regular AEA level monitoring');
  }

  if (riskFactors.stressResponse > 0.4) {
    riskAnalysis.recommendations.push('Enhanced stress management protocols');
    riskAnalysis.monitoring.push('Cortisol rhythm monitoring');
  }

  if (riskFactors.inflammation > 0.25) {
    riskAnalysis.recommendations.push('Anti-inflammatory diet and supplementation');
    riskAnalysis.monitoring.push('Inflammatory marker tracking');
  }

  return riskAnalysis;
};

// Main Component
const ECBomeIntelligenceSystem = () => {
  const [analysisHistory, setAnalysisHistory] = useState(MOCK_DATA.analysisHistory);
  const [currentAnalysis, setCurrentAnalysis] = useState(null);
  const [isRunning, setIsRunning] = useState(false);
  const [insights, setInsights] = useState([]);
  const [systemHealth, setSystemHealth] = useState({
    status: 'healthy',
    dataQuality: 100,
    lastValidation: null
  });
  const [errors, setErrors] = useState([]);
  const [correlationData, setCorrelationData] = useState(MOCK_DATA.crossSystemInteractions);
  const [correlationInsights, setCorrelationInsights] = useState([]);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [loading, setLoading] = useState(false);
  const [patientData, setPatientData] = useState(MOCK_DATA.realTimeMetrics);

  // Advanced Analytics State
  const [predictiveAnalytics, setPredictiveAnalytics] = useState({
    shortTerm: null,
    mediumTerm: null,
    longTerm: null
  });
  const [riskAssessment, setRiskAssessment] = useState({
    score: 0,
    level: 'low',
    factors: [],
    recommendations: []
  });
  const [crossSystemInteractions, setCrossSystemInteractions] = useState(MOCK_DATA.crossSystemInteractions);
  const [temporalPatterns, setTemporalPatterns] = useState(MOCK_DATA.temporalPatterns);
  const [causalAnalysis, setCausalAnalysis] = useState(MOCK_DATA.causalAnalysis);
  const [mlModelStatus, setMlModelStatus] = useState(MOCK_DATA.mlModelStatus);

  // Real-time Monitoring State
  const [realTimeAlerts, setRealTimeAlerts] = useState([]);
  const [dataStreams, setDataStreams] = useState(MOCK_DATA.dataStreams);
  const [interventionHistory, setInterventionHistory] = useState([]);
  const [monitoringStatus, setMonitoringStatus] = useState({
    active: false,
    lastUpdate: null,
    dataPoints: 0,
    alertCount: 0
  });

  // Personalized Medicine State
  const [geneticProfile, setGeneticProfile] = useState(MOCK_DATA.geneticProfile);
  const [personalizedDosing, setPersonalizedDosing] = useState(MOCK_DATA.personalizedDosing);
  const [treatmentProtocol, setTreatmentProtocol] = useState(MOCK_DATA.treatmentProtocol);
  const [geneticRiskAnalysis, setGeneticRiskAnalysis] = useState(null);

  // Load patient data using Abena SDK
  useEffect(() => {
    const loadPatientData = async () => {
      try {
        setLoading(true);
        
        // Try to load real patient data first
        try {
          // Auto-handled auth & permissions through Abena SDK
          const patient = await abena.getPatientData('current_patient', 'ecbome_analysis');
          setPatientData(patient);
          
          // Initialize ECBome Correlation Engine for this patient
          await ecbomeEngine.initializePatientProfile(patient.patientId);
          
          // Load eCBome intelligence data through ECBome engine
          const intelligenceData = await ecbomeEngine.processMultiModuleAnalysis(
            patient.patientId,
            'current_user'
          );
          setCurrentAnalysis(intelligenceData);
          
          // Load historical analysis data
          const history = await abena.getHistoricalData('ecbome_analysis', 'current_patient', {
            timeRange: '30d',
            dataType: 'metrics'
          });
          setAnalysisHistory(history);
        } catch (apiError) {
          console.warn('API data loading failed, using test data:', apiError);
          
          // Fallback to test data
          const { testIntelligenceData } = await import('../data/testData.js');
          
          // Transform test data to match expected format
          const transformedData = testIntelligenceData.map(item => ({
            timestamp: item.timestamp,
            metrics: {
              endocannabinoidLevels: item.endocannabinoidLevels,
              receptorActivity: item.receptorActivity,
              microbiomeHealth: item.microbiomeHealth,
              inflammationMarkers: item.inflammationMarkers,
              stressResponse: item.stressResponse
            }
          }));
          
          setAnalysisHistory(transformedData);
          setCurrentAnalysis(transformedData[transformedData.length - 1]);
          setPatientData({
            patientId: 'TEST123',
            name: 'Test Patient',
            status: 'demo'
          });
        }
        
      } catch (error) {
        console.error('Error loading patient data:', error);
        setErrors(prev => [...prev, `Failed to load patient data: ${error.message}`]);
      } finally {
        setLoading(false);
      }
    };

    loadPatientData();
  }, []);

  // Save analysis data to Abena services
  const saveAnalysisData = async (dataPoint) => {
    try {
      await abena.saveModuleData('ecbome_analysis', {
        patientId: 'current_patient',
        userId: 'current_user',
        data: dataPoint,
        dataType: 'metrics',
        timestamp: new Date().toISOString(),
        encryption: true,
        audit: true
      });
    } catch (error) {
      console.error('Error saving analysis data:', error);
      setErrors(prev => [...prev, `Failed to save analysis data: ${error.message}`]);
    }
  };

  // Update analysis history when new intelligence data arrives
  useEffect(() => {
    if (currentAnalysis) {
      const newDataPoint = {
        timestamp: new Date().toISOString(),
        metrics: currentAnalysis.moduleResults || currentAnalysis.metrics,
        ecbomeCorrelations: currentAnalysis.ecbomeCorrelations,
        patterns: currentAnalysis.patterns,
        predictions: currentAnalysis.predictions,
        clinicalInsights: currentAnalysis.clinicalInsights
      };
      
      setAnalysisHistory(prev => [...prev, newDataPoint]);
      
      // Save to Abena services
      saveAnalysisData(newDataPoint);
      
      // ECBome engine handles its own correlation processing
      // Just get the latest correlation data
      const correlationResult = currentAnalysis.ecbomeCorrelations;
      setCorrelationData(correlationResult);
      
      // Feed correlation data to unified integration layer
      unifiedIntegrationLayer.addRealTimeCorrelations({
        source: 'ECBomeCorrelationEngine',
        data: correlationResult,
        confidence: currentAnalysis.confidenceScore,
        patterns: currentAnalysis.patterns
      });
      
      // Generate correlation insights from ECBome analysis
      const newCorrelationInsights = generateCorrelationInsights(correlationResult);
      setCorrelationInsights(newCorrelationInsights);
      
      // Generate insights from ECBome clinical intelligence
      const newInsights = currentAnalysis.clinicalInsights?.recommendations || 
                          generateInsights([...analysisHistory, newDataPoint]);
      setInsights(newInsights);
      
      // Update system health based on ECBome analysis
      setSystemHealth({
        status: currentAnalysis.systemStatus?.overall || 'healthy',
        dataQuality: currentAnalysis.confidenceScore ? Math.round(currentAnalysis.confidenceScore * 100) : 100,
        lastValidation: new Date().toISOString()
      });

      // Run Advanced Analytics with ECBome integration
      const runAdvancedAnalytics = async () => {
        try {
          // Use ECBome predictive insights instead of local predictions
          if (currentAnalysis.predictions) {
            setPredictiveAnalytics({
              shortTerm: currentAnalysis.predictions.shortTerm || await runPredictiveAnalytics(newDataPoint, 'shortTerm'),
              mediumTerm: currentAnalysis.predictions.mediumTerm || await runPredictiveAnalytics(newDataPoint, 'mediumTerm'),
              longTerm: currentAnalysis.predictions.longTerm || await runPredictiveAnalytics(newDataPoint, 'longTerm')
            });
          }

          // Use ECBome risk assessment
          const riskScore = currentAnalysis.clinicalInsights?.riskProfile || calculateRiskScore(newDataPoint);
          setRiskAssessment(riskScore);

          // Use ECBome cross-system interactions
          const interactions = currentAnalysis.patterns?.systemInteractions || analyzeCrossSystemInteractions(newDataPoint);
          setCrossSystemInteractions(interactions);

          // Use ECBome temporal patterns
          const patterns = currentAnalysis.patterns?.temporalPatterns || detectTemporalPatterns([...analysisHistory, newDataPoint]);
          setTemporalPatterns(patterns);

          // Use ECBome causal analysis
          const causal = currentAnalysis.clinicalInsights?.causalAnalysis || performCausalInference(newDataPoint, []);
          setCausalAnalysis(causal);

          // Update ML model status based on ECBome confidence
          setMlModelStatus(prev => ({
            healthOutcomePrediction: { 
              confidence: currentAnalysis.confidenceScore || 0.85, 
              lastUpdated: new Date().toISOString() 
            },
            interventionOptimization: { 
              confidence: currentAnalysis.confidenceScore || 0.78, 
              lastUpdated: new Date().toISOString() 
            },
            riskAssessment: { 
              confidence: currentAnalysis.confidenceScore || 0.92, 
              lastUpdated: new Date().toISOString() 
            },
            personalizedDosing: { 
              confidence: currentAnalysis.confidenceScore || 0.80, 
              lastUpdated: new Date().toISOString() 
            }
          }));

          // Generate alerts from ECBome provider alerts
          const alerts = currentAnalysis.clinicalInsights?.providerAlerts || 
                         generateSmartAlerts(newDataPoint, RealTimeMonitoring.alertSystem.thresholds);
          setRealTimeAlerts(prev => [...prev, ...alerts]);

          // Use ECBome intervention tracking
          const interventionHistoryItem = currentAnalysis.clinicalInsights?.interventionHistory || 
                                         trackInterventionEffectiveness('baseline', newDataPoint.metrics, newDataPoint.metrics);
          setInterventionHistory(prev => [...prev, interventionHistoryItem]);

          // Monitor data streams with ECBome integration
          const dataStreams = monitorDataStreams(newDataPoint);
          setDataStreams(dataStreams);

          // Update monitoring status
          setMonitoringStatus(prev => ({
            active: true,
            lastUpdate: new Date().toISOString(),
            dataPoints: prev.dataPoints + 1,
            alertCount: prev.alertCount + (Array.isArray(alerts) ? alerts.length : 0)
          }));

          // Calculate personalized medicine recommendations with ECBome integration
          if (patientData && currentAnalysis) {
            const dosing = currentAnalysis.clinicalInsights?.personalizedDosing || 
                          calculatePersonalizedDosing(patientData, geneticProfile, newDataPoint.metrics);
            setPersonalizedDosing(dosing);

            const protocol = currentAnalysis.clinicalInsights?.treatmentProtocol || 
                            generateTreatmentProtocol(
                              patientData, 
                              geneticProfile, 
                              newDataPoint.metrics, 
                              ['stress_reduction', 'inflammation_control', 'sleep_optimization']
                            );
            setTreatmentProtocol(protocol);

            const riskAnalysis = currentAnalysis.clinicalInsights?.geneticRiskAnalysis || 
                               analyzeGeneticRiskFactors(geneticProfile);
            setGeneticRiskAnalysis(riskAnalysis);
          }

        } catch (error) {
          console.error('Error running advanced analytics:', error);
          setErrors(prev => [...prev, `Advanced analytics error: ${error.message}`]);
        }
      };

      runAdvancedAnalytics();
    }
  }, [currentAnalysis, analysisHistory]);

  // Start/Stop analysis using ECBome engine
  const toggleAnalysis = async () => {
    try {
      if (!isRunning) {
        setIsRunning(true);
        // Start ECBome continuous analysis
        await ecbomeEngine.startContinuousAnalysis('current_patient');
        
        // Also start Abena SDK monitoring
        await abena.startModuleService('ecbome_analysis', {
          patientId: 'current_patient',
          userId: 'current_user',
          serviceType: 'continuous_monitoring',
          parameters: {
            updateInterval: 900000, // 15 minutes (aligned with ECBome intervals)
            dataTypes: ['multi_module_analysis', 'ecbome_correlations', 'predictive_insights']
          }
        });
        
        // Set up periodic ECBome analysis updates
        const analysisInterval = setInterval(async () => {
          try {
            const analysisResult = await ecbomeEngine.processMultiModuleAnalysis(
              'current_patient',
              'current_user'
            );
            setCurrentAnalysis(analysisResult);
          } catch (error) {
            console.error('Error in periodic ECBome analysis:', error);
          }
        }, 900000); // 15 minutes
        
        // Store interval for cleanup
        window.ecbomeAnalysisInterval = analysisInterval;
        
      } else {
        setIsRunning(false);
        // Stop ECBome continuous analysis
        await ecbomeEngine.stopContinuousAnalysis();
        
        // Stop Abena SDK monitoring
        await abena.stopModuleService('ecbome_analysis');
        
        // Clear interval
        if (window.ecbomeAnalysisInterval) {
          clearInterval(window.ecbomeAnalysisInterval);
          delete window.ecbomeAnalysisInterval;
        }
      }
    } catch (error) {
      console.error('Error toggling analysis:', error);
      setErrors(prev => [...prev, `Failed to ${isRunning ? 'stop' : 'start'} analysis: ${error.message}`]);
    }
  };

  // Export functionality using Abena SDK
  const exportData = async (format = 'json') => {
    try {
      setLoading(true);
      
      const exportData = {
        analysisHistory: analysisHistory,
        insights: insights,
        systemHealth: systemHealth,
        patient: patientData,
        exportTimestamp: new Date().toISOString()
      };

      // Use Abena SDK for secure data export with audit logging
      const exportResult = await abena.exportData('ecbome_analysis', {
        patientId: 'current_patient',
        userId: 'current_user',
        format: format,
        data: exportData,
        purpose: 'clinical_analysis',
        encryption: true
      });

      // Download the exported file
      const blob = new Blob([exportResult.data], { type: exportResult.mimeType });
      downloadFile(blob, exportResult.filename);

    } catch (error) {
      console.error('Error exporting data:', error);
      setErrors(prev => [...prev, `Failed to export data: ${error.message}`]);
      
      // Fallback to local export
      const exportData = {
        analysisHistory: analysisHistory,
        insights: insights,
        systemHealth: systemHealth,
        patient: patientData,
        exportTimestamp: new Date().toISOString()
      };

      switch (format) {
        case 'json':
          const jsonBlob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
          downloadFile(jsonBlob, `ecbome-analysis-${new Date().toISOString().split('T')[0]}.json`);
          break;
        
        case 'csv':
          const csvContent = generateCSV(exportData);
          const csvBlob = new Blob([csvContent], { type: 'text/csv' });
          downloadFile(csvBlob, `ecbome-analysis-${new Date().toISOString().split('T')[0]}.csv`);
          break;
        
        default:
          console.warn('Unsupported export format:', format);
      }
    } finally {
      setLoading(false);
    }
  };

  // Generate HTML Report using Abena SDK
  const generateHTMLReport = async () => {
    try {
      setLoading(true);
      
      const reportData = {
        patientInfo: {
          name: patientData?.name || 'Patient',
          id: patientData?.id || 'P001',
          date: new Date().toLocaleDateString(),
          provider: 'Dr. Smith'
        },
        analysisResults: {
          overallScore: systemHealth.dataQuality ? Math.round(systemHealth.dataQuality) : 72,
          receptorStatus: [
            { name: 'CB1', score: chartData.length ? chartData[chartData.length-1].CB1 : 85, status: 'Good' },
            { name: 'CB2', score: chartData.length ? chartData[chartData.length-1].CB2 : 70, status: 'Moderate' },
            { name: 'Dopamine', score: chartData.length ? chartData[chartData.length-1].D1 : 68, status: 'Moderate' },
            { name: 'Serotonin', score: chartData.length ? chartData[chartData.length-1]['5-HT1A'] : 65, status: 'Low' },
            { name: 'Hormonal', score: 55, status: 'Low' }
          ],
          biomarkers: [
            { name: 'Anandamide', value: chartData.length ? chartData[chartData.length-1].anandamide : 0.35, unit: 'pmol/mL', status: 'Normal', range: '0.1-0.5' },
            { name: '2-AG', value: chartData.length ? chartData[chartData.length-1]['2-AG'] : 28, unit: 'pmol/mL', status: 'Normal', range: '5-50' },
            { name: 'Testosterone', value: 450, unit: 'ng/dL', status: 'Normal', range: '300-1000' },
            { name: 'Estradiol', value: 25, unit: 'pg/mL', status: 'Low', range: '30-400' },
            { name: 'Cortisol', value: 18, unit: 'μg/dL', status: 'High', range: '6-23' }
          ]
        }
      };

      // Use Abena SDK for secure report generation with audit logging
      const reportResult = await abena.generateReport('ecbome_analysis', {
        patientId: 'current_patient',
        userId: 'current_user',
        reportType: 'html',
        data: reportData,
        template: 'ecbome_comprehensive',
        encryption: true,
        watermark: true
      });

      // Download the generated report
      const blob = new Blob([reportResult.data], { type: 'text/html' });
      downloadFile(blob, reportResult.filename);

    } catch (error) {
      console.error('Error generating HTML report:', error);
      setErrors(prev => [...prev, `Failed to generate report: ${error.message}`]);
      
      // Fallback to local report generation
      const htmlContent = generateLocalHTMLReport();
      const blob = new Blob([htmlContent], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `eCBome-Report-${patientData?.name || 'Patient'}-${new Date().toISOString().split('T')[0]}.html`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    } finally {
      setLoading(false);
    }
  };

  // Generate insights from correlation data
  const generateCorrelationInsights = (correlationData) => {
    if (!correlationData || !correlationData.correlations) return [];
    
    const insights = [];
    
    // Strong correlations
    const strongCorrelations = correlationData.correlations.filter(c => 
      Math.abs(c.correlation) > 0.8 && c.confidence > 0.8
    );
    
    if (strongCorrelations.length > 0) {
      insights.push({
        type: 'strong_correlation',
        severity: 'high',
        message: `${strongCorrelations.length} strong correlations detected between receptor systems`,
        details: strongCorrelations.slice(0, 3).map(c => 
          `${c.metric1} ↔ ${c.metric2} (r=${c.correlation.toFixed(3)})`
        )
      });
    }
    
    // Pattern insights
    const patterns = correlationData.correlations.filter(c => c.pattern && c.pattern.type === 'correlation_pattern');
    const synchronousPatterns = patterns.filter(p => p.pattern.synchronous);
    const laggedPatterns = patterns.filter(p => p.pattern.lagged);
    
    if (synchronousPatterns.length > 0) {
      insights.push({
        type: 'synchronous_pattern',
        severity: 'medium',
        message: `${synchronousPatterns.length} synchronous patterns detected`,
        details: synchronousPatterns.slice(0, 2).map(p => 
          `${p.metric1} and ${p.metric2} move together`
        )
      });
    }
    
    if (laggedPatterns.length > 0) {
      insights.push({
        type: 'lagged_pattern',
        severity: 'medium',
        message: `${laggedPatterns.length} lagged relationships detected`,
        details: laggedPatterns.slice(0, 2).map(p => 
          `${p.metric1} leads ${p.metric2} by ${p.pattern.lagged.lag} periods`
        )
      });
    }
    
    // System health insights
    if (correlationData.summary && correlationData.summary.systemHealth) {
      const health = correlationData.summary.systemHealth;
      if (health.status === 'degraded') {
        insights.push({
          type: 'system_health',
          severity: 'high',
          message: `System correlation health is degraded (score: ${health.score.toFixed(2)})`,
          details: health.typeDistribution && typeof health.typeDistribution === 'object' ? 
            Object.entries(health.typeDistribution).map(([type, count]) => 
              `${type}: ${count} correlations`
            ) : []
        });
      }
    }
    
    return insights;
  };

  // Format chart data
  const formatChartData = (data) => {
    if (!data || data.length === 0) return [];
    return data.map(d => ({
      date: new Date(d.timestamp).toLocaleDateString(),
      // Endocannabinoid levels
      anandamide: d.metrics.endocannabinoidLevels.anandamide * 100,
      '2-AG': d.metrics.endocannabinoidLevels['2-AG'] * 100,
      PEA: d.metrics.endocannabinoidLevels.PEA * 100,
      OEA: d.metrics.endocannabinoidLevels.OEA * 100,
      // Endocannabinoid receptors
      CB1: d.metrics.receptorActivity.CB1 * 100,
      CB2: d.metrics.receptorActivity.CB2 * 100,
      TRPV1: d.metrics.receptorActivity.TRPV1 * 100,
      GPR18: d.metrics.receptorActivity.GPR18 * 100,
      // PPAR receptors
      PPARα: d.metrics.receptorActivity.PPARα * 100,
      PPARγ: d.metrics.receptorActivity.PPARγ * 100,
      PPARδ: d.metrics.receptorActivity.PPARδ * 100,
      // 5-HT receptors
      '5-HT1A': d.metrics.receptorActivity['5-HT1A'] * 100,
      '5-HT2A': d.metrics.receptorActivity['5-HT2A'] * 100,
      '5-HT3': d.metrics.receptorActivity['5-HT3'] * 100,
      '5-HT4': d.metrics.receptorActivity['5-HT4'] * 100,
      '5-HT6': d.metrics.receptorActivity['5-HT6'] * 100,
      '5-HT7': d.metrics.receptorActivity['5-HT7'] * 100,
      // Dopamine receptors
      D1: d.metrics.receptorActivity.D1 * 100,
      D2: d.metrics.receptorActivity.D2 * 100,
      D3: d.metrics.receptorActivity.D3 * 100,
      D4: d.metrics.receptorActivity.D4 * 100,
      D5: d.metrics.receptorActivity.D5 * 100,
      // Adrenergic receptors
      'α1A': d.metrics.receptorActivity['α1A'] * 100,
      'α1B': d.metrics.receptorActivity['α1B'] * 100,
      'α1D': d.metrics.receptorActivity['α1D'] * 100,
      'α2A': d.metrics.receptorActivity['α2A'] * 100,
      'α2B': d.metrics.receptorActivity['α2B'] * 100,
      'α2C': d.metrics.receptorActivity['α2C'] * 100,
      'β1': d.metrics.receptorActivity['β1'] * 100,
      'β2': d.metrics.receptorActivity['β2'] * 100,
      'β3': d.metrics.receptorActivity['β3'] * 100,
      // Other metrics
      microbiomeHealth: d.metrics.microbiomeHealth * 100,
      inflammationMarkers: d.metrics.inflammationMarkers * 100,
      stressResponse: d.metrics.stressResponse * 100
    }));
  };

  const chartData = formatChartData(analysisHistory);

  const generateCSV = (data) => {
    const headers = [
      'Timestamp', 'Anandamide', '2-AG', 'PEA', 'OEA', 
      'CB1', 'CB2', 'TRPV1', 'GPR18',
      'PPARα', 'PPARγ', 'PPARδ',
      '5-HT1A', '5-HT2A', '5-HT3', '5-HT4', '5-HT6', '5-HT7',
      'D1', 'D2', 'D3', 'D4', 'D5',
      'α1A', 'α1B', 'α1D', 'α2A', 'α2B', 'α2C', 'β1', 'β2', 'β3',
      'Microbiome', 'Inflammation', 'Stress'
    ];
    const rows = data.analysisHistory.map(result => [
      new Date(result.timestamp).toISOString(),
      result.metrics.endocannabinoidLevels.anandamide,
      result.metrics.endocannabinoidLevels['2-AG'],
      result.metrics.endocannabinoidLevels.PEA,
      result.metrics.endocannabinoidLevels.OEA,
      result.metrics.receptorActivity.CB1,
      result.metrics.receptorActivity.CB2,
      result.metrics.receptorActivity.TRPV1,
      result.metrics.receptorActivity.GPR18,
      result.metrics.receptorActivity.PPARα,
      result.metrics.receptorActivity.PPARγ,
      result.metrics.receptorActivity.PPARδ,
      result.metrics.receptorActivity['5-HT1A'],
      result.metrics.receptorActivity['5-HT2A'],
      result.metrics.receptorActivity['5-HT3'],
      result.metrics.receptorActivity['5-HT4'],
      result.metrics.receptorActivity['5-HT6'],
      result.metrics.receptorActivity['5-HT7'],
      result.metrics.receptorActivity.D1,
      result.metrics.receptorActivity.D2,
      result.metrics.receptorActivity.D3,
      result.metrics.receptorActivity.D4,
      result.metrics.receptorActivity.D5,
      result.metrics.receptorActivity['α1A'],
      result.metrics.receptorActivity['α1B'],
      result.metrics.receptorActivity['α1D'],
      result.metrics.receptorActivity['α2A'],
      result.metrics.receptorActivity['α2B'],
      result.metrics.receptorActivity['α2C'],
      result.metrics.receptorActivity['β1'],
      result.metrics.receptorActivity['β2'],
      result.metrics.receptorActivity['β3'],
      result.metrics.microbiomeHealth,
      result.metrics.inflammationMarkers,
      result.metrics.stressResponse
    ]);
    
    return [headers, ...rows].map(row => row.join(',')).join('\n');
  };

  const downloadFile = (blob, filename) => {
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    window.URL.revokeObjectURL(url);
    document.body.removeChild(a);
  };

  // HTML Report Generation Function
  const generateLocalHTMLReport = () => {
    const reportData = {
      patientInfo: {
        name: patientData?.name || 'Patient',
        id: patientData?.id || 'P001',
        date: new Date().toLocaleDateString(),
        provider: 'Dr. Smith'
      },
      analysisResults: {
        overallScore: systemHealth.dataQuality ? Math.round(systemHealth.dataQuality) : 72,
        receptorStatus: [
          { name: 'CB1', score: chartData.length ? chartData[chartData.length-1].CB1 : 85, status: 'Good' },
          { name: 'CB2', score: chartData.length ? chartData[chartData.length-1].CB2 : 70, status: 'Moderate' },
          { name: 'Dopamine', score: chartData.length ? chartData[chartData.length-1].D1 : 68, status: 'Moderate' },
          { name: 'Serotonin', score: chartData.length ? chartData[chartData.length-1]['5-HT1A'] : 65, status: 'Low' },
          { name: 'Hormonal', score: 55, status: 'Low' }
        ],
        biomarkers: [
          { name: 'Anandamide', value: chartData.length ? chartData[chartData.length-1].anandamide : 0.35, unit: 'pmol/mL', status: 'Normal', range: '0.1-0.5' },
          { name: '2-AG', value: chartData.length ? chartData[chartData.length-1]['2-AG'] : 28, unit: 'pmol/mL', status: 'Normal', range: '5-50' },
          { name: 'Testosterone', value: 450, unit: 'ng/dL', status: 'Normal', range: '300-1000' },
          { name: 'Estradiol', value: 25, unit: 'pg/mL', status: 'Low', range: '30-400' },
          { name: 'Cortisol', value: 18, unit: 'μg/dL', status: 'High', range: '6-23' }
        ]
      }
    };

    const htmlContent = `
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eCBome Intelligence Report - ${reportData.patientInfo.name}</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
      /* ... (same styles as in AbenaECBomeAnalyzer) ... */
