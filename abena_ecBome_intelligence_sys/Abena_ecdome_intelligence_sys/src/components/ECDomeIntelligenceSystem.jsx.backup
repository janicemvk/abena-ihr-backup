                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    tension: 0.4
                }, {
                    label: 'Cortisol',
                    data: [90, 70, 50, 40, 35, 25, 20],
                    borderColor: 'rgba(245, 158, 11, 1)',
                    backgroundColor: 'rgba(245, 158, 11, 0.1)',
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    title: {
                        display: true,
                        text: 'Daily eCBome & Stress Hormone Patterns'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Relative Levels (%)'
                        }
                    }
                }
            }
        });
        // Hormonal Chart
        const hormonalCtx = document.getElementById('hormonalChart').getContext('2d');
        new Chart(hormonalCtx, {
            type: 'bar',
            data: {
                labels: ['Testosterone', 'Estradiol', 'Cortisol', 'CB1 Expression', 'CB2 Expression'],
                datasets: [{
                    label: 'Current Levels (%)',
                    data: [90, 60, 120, 85, 70],
                    backgroundColor: [
                        'rgba(79, 70, 229, 0.8)',
                        'rgba(236, 72, 153, 0.8)',
                        'rgba(245, 158, 11, 0.8)',
                        'rgba(16, 185, 129, 0.8)',
                        'rgba(139, 92, 246, 0.8)'
                    ]
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    title: {
                        display: true,
                        text: 'Hormonal & Receptor Status (% of Optimal)'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 150,
                        title: {
                            display: true,
                            text: 'Percentage of Optimal Range'
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>`;

    return htmlContent;
  };

  return (
    <div className="p-6 space-y-6">
      {/* Loading State */}
      {loading && !currentAnalysis && (
        <div className="flex items-center justify-center h-64">
          <div className="text-center">
            <div className="w-12 h-12 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
            <p className="text-lg font-medium text-gray-700">Loading eCBome Intelligence System...</p>
            <p className="text-sm text-gray-500 mt-2">Connecting to Abena services</p>
          </div>
        </div>
      )}

      {/* Tab Navigation */}
      <div className="flex space-x-4 mb-6">
        <button
          className={`px-4 py-2 rounded-t-lg font-semibold focus:outline-none ${activeTab === 'dashboard' ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-700'}`}
          onClick={() => setActiveTab('dashboard')}
        >
          eCBome Dashboard
        </button>
        <button
          className={`px-4 py-2 rounded-t-lg font-semibold focus:outline-none ${activeTab === 'advanced' ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-700'}`}
          onClick={() => setActiveTab('advanced')}
        >
          Advanced Analytics
        </button>
        <button
          className={`px-4 py-2 rounded-t-lg font-semibold focus:outline-none ${activeTab === 'monitoring' ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-700'}`}
          onClick={() => setActiveTab('monitoring')}
        >
          Real-time Monitoring
        </button>
        <button
          className={`px-4 py-2 rounded-t-lg font-semibold focus:outline-none ${activeTab === 'personalized' ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-700'}`}
          onClick={() => setActiveTab('personalized')}
        >
          Personalized Medicine
        </button>
        <button
          className={`px-4 py-2 rounded-t-lg font-semibold focus:outline-none ${activeTab === 'comprehensive' ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-700'}`}
          onClick={() => setActiveTab('comprehensive')}
        >
          Comprehensive eCBome Analysis
        </button>
      </div>

      {/* Tab Content */}
      {activeTab === 'dashboard' && (
        <>
          {/* Header */}
          <div className="bg-white p-6 rounded-lg shadow-md">
            <div className="flex items-center justify-between">
              <div>
                <h1 className="text-3xl font-bold text-gray-900">eCBome Intelligence System</h1>
                <p className="text-gray-600 mt-2">Comprehensive Endocannabinoidome Analysis & Monitoring</p>
                <div className="flex items-center mt-2">
                  <div className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${
                    currentAnalysis 
                      ? 'bg-green-100 text-green-800' 
                      : 'bg-yellow-100 text-yellow-800'
                  }`}>
                    <div className={`w-2 h-2 rounded-full mr-1 ${
                      currentAnalysis 
                        ? 'bg-green-500' 
                        : 'bg-yellow-500'
                    }`}></div>
                    {currentAnalysis 
                      ? 'Connected to Abena Services' 
                      : 'Connecting to Abena Services...'}
                  </div>
                </div>
              </div>
              <div className="flex space-x-2">
                <button
                  onClick={toggleAnalysis}
                  disabled={loading}
                  className={`px-4 py-2 rounded-lg font-medium flex items-center space-x-2 ${
                    isRunning 
                      ? 'bg-red-500 text-white hover:bg-red-600' 
                      : 'bg-green-500 text-white hover:bg-green-600'
                  } ${loading ? 'opacity-50 cursor-not-allowed' : ''}`}
                >
                  {loading ? (
                    <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
                  ) : isRunning ? (
                    <Square className="w-4 h-4" />
                  ) : (
                    <Play className="w-4 h-4" />
                  )}
                  <span>{loading ? 'Loading...' : isRunning ? 'Stop' : 'Start'} Analysis</span>
                </button>
                <button
                  onClick={() => exportData('json')}
                  disabled={loading}
                  className={`px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 flex items-center space-x-2 ${loading ? 'opacity-50 cursor-not-allowed' : ''}`}
                >
                  {loading ? (
                    <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
                  ) : (
                    <Download className="w-4 h-4" />
                  )}
                  <span>Export JSON</span>
                </button>
                <button
                  onClick={() => exportData('csv')}
                  disabled={loading}
                  className={`px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 flex items-center space-x-2 ${loading ? 'opacity-50 cursor-not-allowed' : ''}`}
                >
                  {loading ? (
                    <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
                  ) : (
                    <Download className="w-4 h-4" />
                  )}
                  <span>Export CSV</span>
                </button>
                <button
                  onClick={generateHTMLReport}
                  disabled={loading}
                  className={`px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 flex items-center space-x-2 ${loading ? 'opacity-50 cursor-not-allowed' : ''}`}
                >
                  {loading ? (
                    <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
                  ) : (
                    <FileText className="w-4 h-4" />
                  )}
                  <span>Export HTML Report</span>
                </button>
              </div>
            </div>
          </div>

          {/* Error Display */}
          {errors.length > 0 && (
            <div className="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
              <div className="flex items-center justify-between">
                <h3 className="text-lg font-semibold text-red-800 flex items-center">
                  <AlertTriangle className="w-5 h-5 mr-2" />
                  System Errors
                </h3>
                <button
                  onClick={() => setErrors([])}
                  className="text-red-600 hover:text-red-800"
                >
                  Clear
                </button>
              </div>
              <div className="mt-2 space-y-1">
                {errors.slice(-3).map((error, index) => (
                  <div key={index} className="text-sm text-red-700 bg-red-100 p-2 rounded">
                    {error}
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* System Health & Insights Dashboard */}
          <div className="bg-white p-6 rounded-lg shadow-md">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-lg font-semibold">System Intelligence Dashboard</h3>
              <div className={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${
                systemHealth.status === 'healthy' ? 'bg-green-100 text-green-800' :
                systemHealth.status === 'degraded' ? 'bg-yellow-100 text-yellow-800' :
                'bg-red-100 text-red-800'
              }`}>
                <div className={`w-2 h-2 rounded-full mr-2 ${
                  systemHealth.status === 'healthy' ? 'bg-green-500' :
                  systemHealth.status === 'degraded' ? 'bg-yellow-500' :
                  'bg-red-500'
                }`}></div>
                System Status: {systemHealth.status.charAt(0).toUpperCase() + systemHealth.status.slice(1)}
              </div>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
              <div className="bg-gray-50 p-3 rounded-lg">
                <div className="flex items-center">
                  <Activity className="w-5 h-5 text-blue-500 mr-2" />
                  <span className="text-sm font-medium text-gray-700">Data Quality</span>
                </div>
                <p className="text-2xl font-bold text-blue-600">{systemHealth.dataQuality.toFixed(1)}%</p>
              </div>
              
              <div className="bg-gray-50 p-3 rounded-lg">
                <div className="flex items-center">
                  <TrendingUp className="w-5 h-5 text-green-500 mr-2" />
                  <span className="text-sm font-medium text-gray-700">Data Points</span>
                </div>
                <p className="text-2xl font-bold text-green-600">{analysisHistory.length}</p>
              </div>
              
              <div className="bg-gray-50 p-3 rounded-lg">
                <div className="flex items-center">
                  <AlertTriangle className="w-5 h-5 text-orange-500 mr-2" />
                  <span className="text-sm font-medium text-gray-700">Insights</span>
                </div>
                <p className="text-2xl font-bold text-orange-600">{insights.length}</p>
              </div>
            </div>

            {/* Insights Display */}
            {insights.length > 0 && (
              <div className="border-t pt-4">
                <h4 className="text-md font-semibold mb-3">Recent Insights</h4>
                <div className="space-y-2">
                  {insights.slice(-3).map((insight, index) => (
                    <div key={index} className={`p-3 rounded-lg border-l-4 ${
                      insight.severity === 'high' ? 'bg-red-50 border-red-400' :
                      insight.severity === 'medium' ? 'bg-yellow-50 border-yellow-400' :
                      'bg-blue-50 border-blue-400'
                    }`}>
                      <div className="flex items-start justify-between">
                        <div className="flex-1">
                          <div className="flex items-center mb-1">
                            <span className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium mr-2 ${
                              insight.type === 'trend' ? 'bg-blue-100 text-blue-800' :
                              insight.type === 'anomaly' ? 'bg-red-100 text-red-800' :
                              'bg-yellow-100 text-yellow-800'
                            }`}>
                              {insight.type.charAt(0).toUpperCase() + insight.type.slice(1)}
                            </span>
                            <span className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${
                              insight.severity === 'high' ? 'bg-red-100 text-red-800' :
                              insight.severity === 'medium' ? 'bg-yellow-100 text-yellow-800' :
                              'bg-green-100 text-green-800'
                            }`}>
                              {insight.severity.charAt(0).toUpperCase() + insight.severity.slice(1)}
                            </span>
                          </div>
                          <p className="text-sm font-medium text-gray-800">{insight.message}</p>
                          {insight.details && (
                            <div className="mt-2 text-xs text-gray-600">
                              {insight.details.slice(0, 2).map((detail, i) => (
                                <p key={i} className="ml-2">
                                  {typeof detail === 'string' ? detail : 
                                   `${detail.metric}: ${detail.value.toFixed(3)} (expected: ${detail.expected.toFixed(3)})`}
                                </p>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Correlation Dashboard */}
            {correlationData && (
              <div className="border-t pt-4">
                <div className="flex items-center justify-between mb-4">
                  <h4 className="text-md font-semibold flex items-center">
                    <BarChart3 className="w-4 h-4 mr-2 text-purple-500" />
                    Real-Time Correlation Analysis
                  </h4>
                  <div className="text-xs text-gray-500">
                    {correlationData.summary && (
                      <span>
                        {correlationData.summary.totalCorrelations} correlations | 
                        {correlationData.summary.strongCorrelations} strong | 
                        {correlationData.summary.highConfidence} high confidence
                      </span>
                    )}
                  </div>
                </div>

                {/* Correlation Summary Cards */}
                {correlationData.summary && (
                  <div className="grid grid-cols-1 md:grid-cols-4 gap-3 mb-4">
                    <div className="bg-purple-50 p-3 rounded-lg border border-purple-200">
                      <div className="text-xs font-medium text-purple-700">Total Correlations</div>
                      <div className="text-lg font-bold text-purple-800">{correlationData.summary.totalCorrelations}</div>
                    </div>
                    <div className="bg-green-50 p-3 rounded-lg border border-green-200">
                      <div className="text-xs font-medium text-green-700">Strong (r &gt; 0.8)</div>
                      <div className="text-lg font-bold text-green-800">{correlationData.summary.strongCorrelations}</div>
                    </div>
                    <div className="bg-blue-50 p-3 rounded-lg border border-blue-200">
                      <div className="text-xs font-medium text-blue-700">High Confidence</div>
                      <div className="text-lg font-bold text-blue-800">{correlationData.summary.highConfidence}</div>
                    </div>
                    <div className={`p-3 rounded-lg border ${
                      correlationData.summary.systemHealth?.status === 'healthy' 
                        ? 'bg-green-50 border-green-200' 
                        : 'bg-red-50 border-red-200'
                    }`}>
                      <div className={`text-xs font-medium ${
                        correlationData.summary.systemHealth?.status === 'healthy' 
                          ? 'text-green-700' 
                          : 'text-red-700'
                      }`}>System Health</div>
                      <div className={`text-lg font-bold ${
                        correlationData.summary.systemHealth?.status === 'healthy' 
                          ? 'text-green-800' 
                          : 'text-red-800'
                      }`}>
                        {correlationData.summary.systemHealth?.score ? 
                          (correlationData.summary.systemHealth.score * 100).toFixed(0) + '%' : 'N/A'}
                      </div>
                    </div>
                  </div>
                )}

                {/* Top Correlations */}
                {correlationData.correlations && correlationData.correlations.length > 0 && (
                  <div className="mb-4">
                    <h5 className="text-sm font-semibold mb-2 text-gray-700">Top Correlations</h5>
                    <div className="space-y-2">
                      {correlationData.correlations
                        .sort((a, b) => Math.abs(b.correlation) - Math.abs(a.correlation))
                        .slice(0, 5)
                        .map((corr, index) => (
                          <div key={index} className="bg-gray-50 p-3 rounded-lg">
                            <div className="flex items-center justify-between">
                              <div className="flex-1">
                                <div className="text-sm font-medium text-gray-800">
                                  {corr.metric1} ↔ {corr.metric2}
                                </div>
                                <div className="text-xs text-gray-600">
                                  Type: {corr.type.replace(/_/g, ' ')} | 
                                  Confidence: {(corr.confidence * 100).toFixed(0)}%
                                </div>
                              </div>
                              <div className="text-right">
                                <div className={`text-sm font-bold ${
                                  Math.abs(corr.correlation) > 0.8 ? 'text-green-600' :
                                  Math.abs(corr.correlation) > 0.6 ? 'text-yellow-600' : 'text-gray-600'
                                }`}>
                                  r = {corr.correlation.toFixed(3)}
                                </div>
                                <div className="text-xs text-gray-500">
                                  {corr.significance.replace(/_/g, ' ')}
                                </div>
                              </div>
                            </div>
                            {corr.pattern && corr.pattern.type === 'correlation_pattern' && (
                              <div className="mt-2 text-xs text-gray-600">
                                <span className="font-medium">Pattern: </span>
                                {corr.pattern.synchronous && 'Synchronous '}
                                {corr.pattern.lagged && `Lagged (${corr.pattern.lagged.lag} periods) `}
                                {corr.pattern.trend1 !== 'stable' && `${corr.metric1}: ${corr.pattern.trend1} `}
                                {corr.pattern.trend2 !== 'stable' && `${corr.metric2}: ${corr.pattern.trend2}`}
                              </div>
                            )}
                          </div>
                        ))}
                    </div>
                  </div>
                )}

                {/* Correlation Insights */}
                {correlationInsights.length > 0 && (
                  <div>
                    <h5 className="text-sm font-semibold mb-2 text-gray-700">Correlation Insights</h5>
                    <div className="space-y-2">
                      {correlationInsights.slice(-3).map((insight, index) => (
                        <div key={index} className={`p-3 rounded-lg border-l-4 ${
                          insight.severity === 'high' ? 'bg-purple-50 border-purple-400' :
                          insight.severity === 'medium' ? 'bg-indigo-50 border-indigo-400' :
                          'bg-blue-50 border-blue-400'
                        }`}>
                          <div className="flex items-center mb-1">
                            <span className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium mr-2 ${
                              insight.type === 'strong_correlation' ? 'bg-purple-100 text-purple-800' :
                              insight.type === 'synchronous_pattern' ? 'bg-indigo-100 text-indigo-800' :
                              insight.type === 'lagged_pattern' ? 'bg-blue-100 text-blue-800' :
                              'bg-green-100 text-green-800'
                            }`}>
                              {insight.type.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                            </span>
                            <span className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${
                              insight.severity === 'high' ? 'bg-red-100 text-red-800' :
                              insight.severity === 'medium' ? 'bg-yellow-100 text-yellow-800' :
                              'bg-green-100 text-green-800'
                            }`}>
                              {insight.severity.charAt(0).toUpperCase() + insight.severity.slice(1)}
                            </span>
                          </div>
                          <p className="text-sm font-medium text-gray-800">{insight.message}</p>
                          {insight.details && (
                            <div className="mt-2 text-xs text-gray-600">
                              {insight.details.map((detail, i) => (
                                <p key={i} className="ml-2">• {detail}</p>
                              ))}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>

          {/* Charts Grid */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">Endocannabinoid Levels</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="anandamide" stroke="#4BC0C0" name="Anandamide" />
                    <Line type="monotone" dataKey="2-AG" stroke="#FF6384" name="2-AG" />
                    <Line type="monotone" dataKey="PEA" stroke="#36A2EB" name="PEA" />
                    <Line type="monotone" dataKey="OEA" stroke="#9966FF" name="OEA" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">Endocannabinoid Receptors</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="CB1" stroke="#FF9F40" name="CB1" />
                    <Line type="monotone" dataKey="CB2" stroke="#4BC0C0" name="CB2" />
                    <Line type="monotone" dataKey="TRPV1" stroke="#36A2EB" name="TRPV1" />
                    <Line type="monotone" dataKey="GPR18" stroke="#9966FF" name="GPR18" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">PPAR Receptors</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="PPARα" stroke="#FF6384" name="PPARα" />
                    <Line type="monotone" dataKey="PPARγ" stroke="#36A2EB" name="PPARγ" />
                    <Line type="monotone" dataKey="PPARδ" stroke="#9966FF" name="PPARδ" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">Serotonin (5-HT) Receptors</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="5-HT1A" stroke="#FF9F40" name="5-HT1A" />
                    <Line type="monotone" dataKey="5-HT2A" stroke="#4BC0C0" name="5-HT2A" />
                    <Line type="monotone" dataKey="5-HT3" stroke="#36A2EB" name="5-HT3" />
                    <Line type="monotone" dataKey="5-HT4" stroke="#9966FF" name="5-HT4" />
                    <Line type="monotone" dataKey="5-HT6" stroke="#FF6384" name="5-HT6" />
                    <Line type="monotone" dataKey="5-HT7" stroke="#C9CBCF" name="5-HT7" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">Dopamine Receptors</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="D1" stroke="#FF9F40" name="D1" />
                    <Line type="monotone" dataKey="D2" stroke="#4BC0C0" name="D2" />
                    <Line type="monotone" dataKey="D3" stroke="#36A2EB" name="D3" />
                    <Line type="monotone" dataKey="D4" stroke="#9966FF" name="D4" />
                    <Line type="monotone" dataKey="D5" stroke="#FF6384" name="D5" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">Adrenergic Receptors</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="α1A" stroke="#FF9F40" name="α1A" />
                    <Line type="monotone" dataKey="α2A" stroke="#4BC0C0" name="α2A" />
                    <Line type="monotone" dataKey="β1" stroke="#36A2EB" name="β1" />
                    <Line type="monotone" dataKey="β2" stroke="#9966FF" name="β2" />
                    <Line type="monotone" dataKey="β3" stroke="#FF6384" name="β3" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-lg font-semibold mb-4">System Health Metrics</h3>
              <div className="h-[300px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={chartData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="date" />
                    <YAxis domain={[0, 100]} />
                    <Tooltip />
                    <Legend />
                    <Line type="monotone" dataKey="microbiomeHealth" stroke="#4BC0C0" name="Microbiome" />
                    <Line type="monotone" dataKey="inflammationMarkers" stroke="#FF6384" name="Inflammation" />
                    <Line type="monotone" dataKey="stressResponse" stroke="#36A2EB" name="Stress" />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>
          </div>
        </>
      )}
      {activeTab === 'advanced' && (
        <div className="space-y-8 bg-gradient-to-br from-purple-50 to-indigo-50 p-6 rounded-xl">
