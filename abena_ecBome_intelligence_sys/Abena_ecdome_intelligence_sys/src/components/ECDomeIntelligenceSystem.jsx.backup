          </div>
          
          {/* Drug Interactions & Safety */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <AlertTriangle className="w-6 h-6 mr-2 text-orange-600" />
              Pharmaceutical-eCBome Interactions
            </h3>
            <div className="text-gray-500">[Drug interaction data will be loaded from Abena services]</div>
            
            {/* Safety Disclaimer */}
            <div className="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg">
              <h4 className="font-semibold text-red-900 mb-2">⚠️ Important Safety Information</h4>
              <div className="text-sm text-red-700">
                <p><strong>Current medications may interact with cannabinoid therapy.</strong> Monitor closely for:</p>
