                      <h5 className="font-semibold text-orange-800">{alert.message}</h5>
                      <p className="text-sm text-gray-600">{alert.timestamp}</p>
                    </div>
                    <div className="text-sm font-medium text-gray-500">{alert.action}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          {/* Data Streams */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Activity className="w-6 h-6 mr-2 text-green-600" />
              Data Streams
            </h3>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
              {dataStreams && typeof dataStreams === 'object' ? Object.entries(dataStreams).map(([stream, data]) => (
                <div key={stream} className="p-4 bg-blue-50 rounded-lg">
                  <h4 className="font-semibold text-blue-900">{stream}</h4>
                  <div className="space-y-2">
                    {data && typeof data === 'object' ? Object.entries(data).map(([metric, value]) => (
                      <div key={metric} className="flex justify-between items-center">
                        <span className="text-sm text-blue-700 capitalize">{metric}</span>
                        <span className="text-sm font-medium text-blue-800">{typeof value === 'number' ? value.toFixed(2) : value}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
          {/* Intervention History */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Heart className="w-6 h-6 mr-2 text-pink-600" />
              Intervention History
            </h3>
            <div className="space-y-4">
              {interventionHistory.map((historyItem, index) => (
                <div key={index} className="bg-pink-50 rounded-lg p-4">
                  <div className="flex items-center justify-between">
                    <div className="flex-1">
                      <h5 className="font-semibold text-pink-800">{historyItem.intervention}</h5>
                      <p className="text-sm text-pink-700">{historyItem.timestamp}</p>
                    </div>
                    <div className="text-sm font-medium text-pink-600">
                      <strong>Improvements:</strong> {historyItem.improvements && typeof historyItem.improvements === 'object' ? Object.entries(historyItem.improvements).map(([metric, improvement]) => (
                        <p key={metric} className="mt-1">{metric}: {improvement.toFixed(2)}%</p>
                      ))}
                    </div>
                    <div className="text-sm font-medium text-pink-600">
                      <strong>Side Effects:</strong> {historyItem.sideEffects.join(', ')}
                    </div>
                    <div className="text-sm font-medium text-pink-600">
                      <strong>Compliance:</strong> {historyItem.compliance.toFixed(2)}%
                    </div>
                    <div className="text-sm font-medium text-pink-600">
                      <strong>Satisfaction:</strong> {historyItem.satisfaction.toFixed(2)}%
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}
      {activeTab === 'personalized' && (
        <div className="space-y-8 bg-gradient-to-br from-purple-50 to-indigo-50 p-6 rounded-xl">
          {/* Personalized Medicine Header */}
          <div className="text-center">
            <h1 className="text-3xl font-bold text-indigo-900 mb-2">
              Personalized Medicine & Treatment Optimization
            </h1>
            <p className="text-lg text-indigo-700">
              AI-Powered Genetic Profiling and Precision Dosing
            </p>
          </div>

          {/* Genetic Profiling Dashboard */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Brain className="w-6 h-6 mr-2 text-purple-600" />
              Genetic Profiling & Risk Assessment
            </h3>
            
            {geneticRiskAnalysis ? (
              <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                {/* Risk Score */}
                <div className="p-4 bg-gradient-to-br from-purple-50 to-indigo-50 rounded-lg border border-purple-200">
                  <div className="text-center">
                    <div className="text-3xl font-bold text-purple-800 mb-2">
                      {(geneticRiskAnalysis.overallRisk * 100).toFixed(0)}%
                    </div>
                    <div className="text-sm text-purple-600">Overall Genetic Risk</div>
                  </div>
                </div>

                {/* Personalized Traits */}
                <div className="p-4 bg-blue-50 rounded-lg">
                  <h4 className="font-semibold text-blue-800 mb-3">Personalized Traits</h4>
                  <div className="space-y-2">
                    {geneticProfile.personalizedTraits && typeof geneticProfile.personalizedTraits === 'object' ? Object.entries(geneticProfile.personalizedTraits).map(([trait, value]) => (
                      <div key={trait} className="flex justify-between items-center">
                        <span className="text-sm text-blue-700 capitalize">
                          {trait.replace(/([A-Z])/g, ' $1').trim()}
                        </span>
                        <span className={`text-sm font-medium px-2 py-1 rounded ${
                          value === 'high' ? 'bg-green-100 text-green-800' :
                          value === 'moderate' ? 'bg-yellow-100 text-yellow-800' :
                          'bg-red-100 text-red-800'
                        }`}>
                          {value}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <div className="text-gray-500">Loading genetic analysis...</div>
            )}

            {/* Genetic Recommendations */}
            {geneticRiskAnalysis && (
              <div className="mt-6">
                <h4 className="font-semibold text-purple-800 mb-3">Genetic-Based Recommendations</h4>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div className="p-4 bg-green-50 rounded-lg">
                    <h5 className="font-semibold text-green-800 mb-2">Recommendations</h5>
                    <ul className="text-sm text-green-700 space-y-1">
                      {geneticRiskAnalysis.recommendations.map((rec, index) => (
                        <li key={index}>• {rec}</li>
                      ))}
                    </ul>
                  </div>
                  <div className="p-4 bg-blue-50 rounded-lg">
                    <h5 className="font-semibold text-blue-800 mb-2">Monitoring</h5>
                    <ul className="text-sm text-blue-700 space-y-1">
                      {geneticRiskAnalysis.monitoring.map((monitor, index) => (
                        <li key={index}>• {monitor}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* Personalized Dosing Dashboard */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Target className="w-5 h-5 mr-2 text-green-600" />
              Personalized Dosing Recommendations
            </h3>
            
            {personalizedDosing ? (
              <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                {/* CBD Dosing */}
                <div className="p-4 bg-green-50 rounded-lg">
                  <h4 className="font-semibold text-green-800 mb-3">CBD Therapy</h4>
                  <div className="space-y-2">
                    <div className="flex justify-between">
                      <span className="text-sm text-green-700">Recommended Dose:</span>
                      <span className="text-sm font-medium text-green-800">{personalizedDosing.cbd.recommendedDose}mg</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-sm text-green-700">Weight Factor:</span>
                      <span className="text-sm font-medium text-green-800">{personalizedDosing.cbd.weightFactor.toFixed(2)}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-sm text-green-700">Metabolism Factor:</span>
                      <span className="text-sm font-medium text-green-800">{personalizedDosing.cbd.metabolismFactor.toFixed(2)}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-sm text-green-700">Genetic Factor:</span>
                      <span className="text-sm font-medium text-green-800">{personalizedDosing.cbd.geneticFactor.toFixed(2)}</span>
                    </div>
                    <div className="mt-3 p-2 bg-green-100 rounded">
                      <div className="text-xs text-green-800 font-medium">Titration:</div>
                      <div className="text-xs text-green-700">{personalizedDosing.cbd.titration}</div>
                    </div>
                  </div>
                </div>

                {/* THC Dosing */}
                <div className="p-4 bg-purple-50 rounded-lg">
                  <h4 className="font-semibold text-purple-800 mb-3">THC Therapy</h4>
                  <div className="space-y-2">
                    <div className="flex justify-between">
                      <span className="text-sm text-purple-700">Recommended Dose:</span>
                      <span className="text-sm font-medium text-purple-800">{personalizedDosing.thc.recommendedDose}mg</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-sm text-purple-700">Tolerance Factor:</span>
                      <span className="text-sm font-medium text-purple-800">{personalizedDosing.thc.toleranceFactor.toFixed(2)}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-sm text-purple-700">Sensitivity Factor:</span>
                      <span className="text-sm font-medium text-purple-800">{personalizedDosing.thc.sensitivityFactor.toFixed(2)}</span>
