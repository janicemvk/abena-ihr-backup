                    </div>
                  </div>
                </div>

                {/* Supplement Dosing */}
                <div className="md:col-span-2 p-4 bg-blue-50 rounded-lg">
                  <h4 className="font-semibold text-blue-800 mb-3">Supplement Recommendations</h4>
                  <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
