                  <Line type="monotone" dataKey="2AG" stroke="#82ca9d" strokeWidth={2} />
                  <Line type="monotone" dataKey="Cortisol" stroke="#ffc658" strokeWidth={2} />
                  <Line type="monotone" dataKey="Testosterone" stroke="#ff7300" strokeWidth={2} />
