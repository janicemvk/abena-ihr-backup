                  <div className="text-xs text-gray-500">
                    Confidence: {(predictiveAnalytics.mediumTerm.confidence * 100).toFixed(0)}%
                  </div>
                </div>
              ) : (
                <div className="text-gray-500">Loading predictions...</div>
              )}
            </div>

            {/* Long-term Predictions */}
            <div className="bg-white p-6 rounded-lg shadow-sm">
              <h3 className="text-lg font-semibold mb-4 flex items-center">
                <Target className="w-5 h-5 mr-2 text-purple-600" />
                Long-term (30d)
              </h3>
              {predictiveAnalytics.longTerm ? (
                <div className="space-y-3">
                  <div className="p-3 bg-purple-50 rounded-lg">
                    <div className="text-sm font-medium text-purple-800">Condition Progression</div>
                    <div className="text-sm text-purple-700 mt-1">
                      {predictiveAnalytics.longTerm.chronicConditionProgression.replace(/_/g, ' ')}
                    </div>
                  </div>
                  <div className="p-3 bg-indigo-50 rounded-lg">
                    <div className="text-sm font-medium text-indigo-800">Preventive Measures</div>
                    <ul className="text-sm text-indigo-700 mt-1">
                      {predictiveAnalytics.longTerm.preventiveMeasures.map((measure, index) => (
                        <li key={index}>• {measure.replace(/_/g, ' ')}</li>
