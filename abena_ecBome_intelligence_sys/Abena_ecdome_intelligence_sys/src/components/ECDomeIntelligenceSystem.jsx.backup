              </div>
              <div className="p-4 bg-blue-50 rounded-lg">
                <h4 className="font-semibold text-blue-900">Last Update</h4>
                <p className="text-sm text-blue-700">{monitoringStatus.lastUpdate ? new Date(monitoringStatus.lastUpdate).toLocaleString() : 'Never'}</p>
              </div>
              <div className="p-4 bg-green-50 rounded-lg">
                <h4 className="font-semibold text-green-900">Data Points</h4>
                <p className="text-sm text-green-700">{monitoringStatus.dataPoints}</p>
              </div>
              <div className="p-4 bg-yellow-50 rounded-lg">
                <h4 className="font-semibold text-yellow-900">Alerts</h4>
                <p className="text-sm text-yellow-700">{monitoringStatus.alertCount}</p>
              </div>
            </div>
          </div>
          {/* Real-time Alerts */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <AlertTriangle className="w-6 h-6 mr-2 text-orange-600" />
              Real-time Alerts
            </h3>
            <div className="space-y-4">
              {realTimeAlerts.map((alert, index) => (
                <div key={index} className="bg-orange-50 rounded-lg p-4">
