                <p className="mt-2"><strong>Always consult with your healthcare provider before making changes to medication regimens.</strong></p>
              </div>
            </div>
          </div>
          
          {/* Cannabis Strain Recommendations */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Leaf className="w-6 h-6 mr-2 text-green-600" />
              Personalized Cannabis Recommendations (eCBome)
            </h3>
            <div className="text-gray-500">[Cannabis recommendations will be loaded from Abena services]</div>
          </div>

          {/* Sexual Health & Hormonal Integration Panel */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Heart className="w-6 h-6 mr-2 text-pink-600" />
              Sexual Health & Hormonal Integration (eCBome)
            </h3>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div className="p-4 bg-pink-50 rounded-lg">
                <h4 className="font-semibold text-pink-900">Hormonal Balance</h4>
                <div className="space-y-2 mt-2">
                  <div className="flex justify-between">
                    <span className="text-sm">Testosterone</span>
                    <span className="text-sm font-medium text-green-600">Optimal</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-sm">Estradiol</span>
                    <span className="text-sm font-medium text-yellow-600">Low</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-sm">Oxytocin</span>
                    <span className="text-sm font-medium text-green-600">Good</span>
                  </div>
                  <div className="flex justify-between">
                    <span className="text-sm">Cortisol</span>
                    <span className="text-sm font-medium text-red-600">High</span>
                  </div>
                </div>
              </div>
              <div className="p-4 bg-purple-50 rounded-lg">
                <h4 className="font-semibold text-purple-900">eCBome-Sexual Health</h4>
                <ul className="text-sm text-purple-700 mt-2 space-y-1">
                  <li>• CB1 modulates sexual desire</li>
                  <li>• AEA enhances intimacy</li>
                  <li>• 2-AG supports arousal</li>
                  <li>• Hormones regulate eCBome</li>
                  <li>• Estrogen enhances CB1 signaling</li>
                  <li>• Testosterone modulates CB1 expression</li>
                </ul>
              </div>
              <div className="p-4 bg-blue-50 rounded-lg">
                <h4 className="font-semibold text-blue-900">Optimization</h4>
                <ul className="text-sm text-blue-700 mt-2 space-y-1">
                  <li>• Evening cannabis for intimacy</li>
                  <li>• Hormone-eCBome timing</li>
                  <li>• Stress reduction protocols</li>
                  <li>• Relationship enhancement</li>
                  <li>• Bioidentical hormone consultation</li>
                  <li>• Partner meditation synchronization</li>
                </ul>
              </div>
            </div>
            
            {/* Hormonal Chart */}
            <div className="mt-6">
              <h4 className="text-lg font-semibold mb-4">Hormonal & Receptor Status</h4>
              <div className="h-64">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart data={[
                    { metric: 'Testosterone', current: 90, optimal: 100, status: 'Optimal' },
                    { metric: 'Estradiol', current: 60, optimal: 100, status: 'Low' },
                    { metric: 'Cortisol', current: 120, optimal: 100, status: 'High' },
                    { metric: 'CB1 Expression', current: 85, optimal: 100, status: 'Good' },
                    { metric: 'CB2 Expression', current: 70, optimal: 100, status: 'Moderate' },
                    { metric: 'AEA Levels', current: 75, optimal: 100, status: 'Good' }
                  ]}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="metric" />
                    <YAxis domain={[0, 150]} />
                    <Tooltip />
                    <Legend />
                    <Bar dataKey="current" fill="#8884d8" name="Current Levels (%)" />
                    <Bar dataKey="optimal" fill="#82ca9d" name="Optimal Range (%)" />
                  </BarChart>
                </ResponsiveContainer>
              </div>
            </div>
          </div>

          {/* Neurotransmitter Network Analysis */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Brain className="w-6 h-6 mr-2 text-indigo-600" />
              Neurotransmitter Network Integration (eCBome)
            </h3>
            <div className="h-80">
              <ResponsiveContainer width="100%" height="100%">
                <RadarChart data={[
                  { system: 'eCBome', current: systemHealth.dataQuality || 72, optimal: 100, interaction: 85 },
                  { system: 'Dopamine', current: chartData.length ? chartData[chartData.length-1].D1 : 68, optimal: 100, interaction: 80 },
                  { system: 'Serotonin', current: chartData.length ? chartData[chartData.length-1]['5-HT1A'] : 65, optimal: 100, interaction: 75 },
                  { system: 'GABA', current: 78, optimal: 100, interaction: 88 },
                  { system: 'Opioid', current: 60, optimal: 100, interaction: 70 },
                  { system: 'Hormonal', current: 55, optimal: 100, interaction: 65 }
                ]}>
                  <PolarGrid />
                  <PolarAngleAxis dataKey="system" />
                  <PolarRadiusAxis angle={0} domain={[0, 100]} />
                  <Radar name="Current Function" dataKey="current" stroke="#8884d8" fill="#8884d8" fillOpacity={0.3} />
                  <Radar name="eCBome Interaction" dataKey="interaction" stroke="#82ca9d" fill="#82ca9d" fillOpacity={0.2} />
                  <Legend />
                </RadarChart>
              </ResponsiveContainer>
            </div>
            
            {/* Neurotransmitter Details */}
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
              <div className="p-4 bg-indigo-50 rounded-lg">
                <h4 className="font-semibold text-indigo-900 mb-2">Key Interactions</h4>
                <ul className="text-sm text-indigo-700 space-y-1">
                  <li>• CB1 modulates dopamine release</li>
                  <li>• Serotonin-eCBome bidirectional modulation</li>
                  <li>• GABA-eCBome stress response</li>
                  <li>• Opioid-eCBome pain synergy</li>
                  <li>• Hormonal receptor expression</li>
                </ul>
              </div>
              <div className="p-4 bg-green-50 rounded-lg">
                <h4 className="font-semibold text-green-900 mb-2">Therapeutic Implications</h4>
                <ul className="text-sm text-green-700 space-y-1">
                  <li>• Cannabis + SSRIs: Monitor interactions</li>
                  <li>• Opioid reduction with eCBome support</li>
                  <li>• GABA enhancement for anxiety</li>
                  <li>• Hormonal optimization timing</li>
                  <li>• Personalized neurotransmitter balance</li>
                </ul>
              </div>
            </div>
          </div>

          {/* Treatment Recommendations */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div className="bg-white p-6 rounded-lg shadow-sm">
              <h3 className="text-xl font-semibold mb-4 flex items-center">
                <Leaf className="w-6 h-6 mr-2 text-green-600" />
                Cannabimimetic Interventions (eCBome)
              </h3>
              <div className="text-gray-500">[Treatment recommendations will be loaded from Abena services]</div>
            </div>

            <div className="bg-white p-6 rounded-lg shadow-sm">
              <h3 className="text-xl font-semibold mb-4 flex items-center">
                <Zap className="w-6 h-6 mr-2 text-purple-600" />
                Personalized Protocol (eCBome)
              </h3>
              <div className="text-gray-500">[Personalized protocols will be loaded from Abena services]</div>
            </div>
          </div>
          
          {/* Final Integration Note */}
          <div className="bg-indigo-100 border border-indigo-300 rounded-lg p-6">
            <h4 className="font-semibold text-indigo-900 mb-2">
              🧠 eCBome Intelligence Integration
            </h4>
            <p className="text-indigo-800">
              This comprehensive analysis runs continuously in the background of all eCBome IHR modules, 
              cross-referencing every health metric, lab result, and intervention through 
              the lens of endocannabinoidome optimization. Each recommendation is 
              personalized based on your unique eCBome profile and current health status.
            </p>
          </div>
        </div>
      )}
    </div>
  );
};

export default ECBomeIntelligenceSystem; 