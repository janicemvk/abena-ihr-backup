const calculateRiskScore = (data) => {
  // Guard against null/undefined data
  if (!data || !data.metrics) {
    return {
      score: 0,
      level: 'low',
      factors: [],
      recommendations: []
    };
  }

  // Advanced risk assessment algorithm
  const riskFactors = {
    inflammation: (data.metrics.inflammationMarkers || 0) > 0.5 ? 0.3 : 0,
    stress: (data.metrics.stressResponse || 0) > 0.6 ? 0.25 : 0,
    microbiome: (data.metrics.microbiomeHealth || 1) < 0.7 ? 0.2 : 0,
    receptorImbalance: data.metrics.receptorActivity && 
      Math.abs((data.metrics.receptorActivity.CB1 || 0) - (data.metrics.receptorActivity.CB2 || 0)) > 0.2 ? 0.15 : 0,
    endocannabinoidDeficiency: data.metrics.endocannabinoidLevels && 
      (data.metrics.endocannabinoidLevels.anandamide || 1) < 0.4 ? 0.1 : 0
  };

  const totalRisk = Object.values(riskFactors).reduce((sum, risk) => sum + risk, 0);
  
  return {
    score: totalRisk,
    level: totalRisk > 0.7 ? 'high' : totalRisk > 0.4 ? 'medium' : 'low',
    factors: riskFactors && typeof riskFactors === 'object' ? Object.entries(riskFactors).filter(([_, value]) => value > 0) : [],
    recommendations: generateRiskMitigationRecommendations(riskFactors)
  };
};

const generateRiskMitigationRecommendations = (riskFactors) => {
  const recommendations = [];
  
  if (riskFactors.inflammation > 0) {
    recommendations.push('Anti-inflammatory diet, omega-3 supplementation');
  }
  if (riskFactors.stress > 0) {
    recommendations.push('Stress reduction techniques, meditation, breathwork');
  }
  if (riskFactors.microbiome > 0) {
    recommendations.push('Probiotic supplementation, prebiotic fiber');
  }
  if (riskFactors.receptorImbalance > 0) {
    recommendations.push('Balanced cannabinoid therapy, receptor-specific interventions');
  }
  if (riskFactors.endocannabinoidDeficiency > 0) {
    recommendations.push('Cannabimimetic practices, FAAH inhibition');
  }
  
  return recommendations;
};

const analyzeCrossSystemInteractions = (data) => {
  const interactions = {
    cardiovascular: {
      heartRate: data.metrics.receptorActivity.CB1 * 0.8 + data.metrics.stressResponse * 0.2,
      bloodPressure: data.metrics.receptorActivity.CB2 * 0.6 + data.metrics.inflammationMarkers * 0.4,
      correlation: 0.75
    },
    endocrine: {
      cortisol: data.metrics.stressResponse * 0.9,
      insulin: data.metrics.receptorActivity.PPARγ * 0.7,
      correlation: 0.68
    },
    immune: {
      inflammation: data.metrics.inflammationMarkers * 0.8 + data.metrics.receptorActivity.CB2 * 0.2,
      immuneResponse: data.metrics.microbiomeHealth * 0.6 + data.metrics.receptorActivity.CB2 * 0.4,
      correlation: 0.82
    },
    nervous: {
      stressResponse: data.metrics.stressResponse * 0.9,
      neurotransmitterBalance: data.metrics.receptorActivity['5-HT1A'] * 0.5 + data.metrics.receptorActivity.D1 * 0.5,
      correlation: 0.71
    }
  };

  return interactions;
};

