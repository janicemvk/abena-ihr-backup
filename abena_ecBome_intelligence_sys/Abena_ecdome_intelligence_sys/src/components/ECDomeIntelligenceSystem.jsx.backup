                      <div className="text-sm font-medium text-red-800">Risk Alerts</div>
                      <ul className="text-sm text-red-700 mt-1">
                        {predictiveAnalytics.shortTerm.riskAlerts.map((alert, index) => (
                          <li key={index}>• {alert.replace(/_/g, ' ')}</li>
