                    <div className="text-sm font-medium text-blue-800">Treatment Adjustments</div>
                    <ul className="text-sm text-blue-700 mt-1">
                      {predictiveAnalytics.mediumTerm.treatmentAdjustments.map((adjustment, index) => (
                        <li key={index}>• {adjustment.replace(/_/g, ' ')}</li>
                      ))}
