            </p>
          </div>

          {/* ML Model Status Dashboard */}
          <div className="bg-white p-6 rounded-lg shadow-sm">
            <h3 className="text-xl font-semibold mb-4 flex items-center">
              <Brain className="w-6 h-6 mr-2 text-purple-600" />
              Machine Learning Model Status
            </h3>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              {mlModelStatus && typeof mlModelStatus === 'object' ? Object.entries(mlModelStatus).map(([model, status]) => (
                <div key={model} className="p-4 bg-gradient-to-br from-purple-50 to-indigo-50 rounded-lg border border-purple-200">
                  <div className="flex items-center justify-between mb-2">
                    <h4 className="font-semibold text-purple-900 capitalize">
                      {model.replace(/([A-Z])/g, ' $1').trim()}
                    </h4>
                    <div className={`w-3 h-3 rounded-full ${
                      status.confidence > 0.8 ? 'bg-green-500' :
                      status.confidence > 0.6 ? 'bg-yellow-500' : 'bg-red-500'
                    }`}></div>
                  </div>
                  <div className="text-2xl font-bold text-purple-800 mb-1">
                    {(status.confidence * 100).toFixed(0)}%
                  </div>
                  <div className="text-sm text-purple-600">Confidence</div>
                  {status.lastUpdated && (
                    <div className="text-xs text-purple-500 mt-2">
                      Updated: {new Date(status.lastUpdated).toLocaleTimeString()}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>

          {/* Predictive Analytics Dashboard */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            {/* Short-term Predictions */}
            <div className="bg-white p-6 rounded-lg shadow-sm">
              <h3 className="text-lg font-semibold mb-4 flex items-center">
                <Clock className="w-5 h-5 mr-2 text-blue-600" />
                Short-term (24h)
              </h3>
              {predictiveAnalytics.shortTerm ? (
                <div className="space-y-3">
                  <div className="p-3 bg-blue-50 rounded-lg">
                    <div className="text-sm font-medium text-blue-800">Next Optimization Window</div>
