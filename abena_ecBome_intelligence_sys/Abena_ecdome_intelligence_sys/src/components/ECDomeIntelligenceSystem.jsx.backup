              {predictiveAnalytics.mediumTerm ? (
                <div className="space-y-3">
                  <div className="p-3 bg-green-50 rounded-lg">
                    <div className="text-sm font-medium text-green-800">Weekly Trends</div>
                    <ul className="text-sm text-green-700 mt-1">
